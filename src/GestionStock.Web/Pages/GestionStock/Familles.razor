@page "/familles"
@attribute [Authorize]
@inject IApiService Api
@inject NavigationManager Nav

<PageTitle>Familles</PageTitle>

<div class="page-header">
    <h1 class="page-title">Familles d'articles</h1>
    <AuthorizeView Roles="Admin">
        <Authorized>
            <button class="btn-primary" @onclick="CreerFamille">+ Nouvelle famille</button>
        </Authorized>
    </AuthorizeView>
</div>

@if (!string.IsNullOrEmpty(message))
{
    <div class="@msgCls">@message</div>
}

@if (chargement)
{
    <div class="loading-state"><div class="spinner-lg"></div></div>
}
else
{
    <div class="table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Libelle</th>
                    <th>Famille parente</th>
                    <th>Description</th>
                    <th>Suivi stock</th>
                    <th>Couleur</th>
                    <th>Ordre</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in familles)
                {
                    <tr>
                        <td><code>@f.Code</code></td>
                        <td class="@(GetLibelleCls(f))">@f.Libelle</td>
                        <td class="text-muted">@(f.ParentLibelle ?? "—")</td>
                        <td class="text-muted small">@f.Description</td>
                        <td>
                            <span class="badge @(f.SansSuiviStock ? "badge-gray" : "badge-blue")">
                                @(f.SansSuiviStock ? "Sans suivi" : "Avec suivi")
                            </span>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(f.Couleur))
                            {
                                <span class="color-dot" style="background:@f.Couleur"></span>
                                <code class="small">@f.Couleur</code>
                            }
                        </td>
                        <td class="text-muted">@f.Ordre</td>
                        <td>
                            @if (f.EstActif)
                            {
                                <span class="badge badge-green">Actif</span>
                            }
                            else
                            {
                                <span class="badge badge-gray">Inactif</span>
                            }
                        </td>
                        <td>
                            <div class="action-btns">
                                <button class="btn-action btn-action-blue" @onclick="() => ModifierFamille(f.Id)">Modifier</button>
                                <AuthorizeView Roles="Admin">
                                    <Authorized>
                                        <button class="btn-action btn-action-blue" @onclick="() => CreerSousFamille(f.Id)">+ Sous-famille</button>
                                        @if (f.EstActif)
                                        {
                                            <button class="btn-action btn-action-red" @onclick="() => Desactiver(f.Id)">Desactiver</button>
                                        }
                                    </Authorized>
                                </AuthorizeView>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (!familles.Any())
    {
        <div class="empty-state">Aucune famille. Creez-en une.</div>
    }
}

@code {
    private List<FamilleArticleDto> familles = new();
    private bool chargement = true;
    private string? message;
    private string msgCls = "alert-success";

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        chargement = true;
        familles = await Api.GetFamillesAsync(false) ?? new();
        chargement = false;
    }

    private void CreerFamille() => Nav.NavigateTo("/familles/nouveau");

    private void ModifierFamille(Guid id) => Nav.NavigateTo($"/familles/modifier/{id}");

    private void CreerSousFamille(Guid id) => Nav.NavigateTo($"/familles/nouveau?parentId={id}");

    private async Task Desactiver(Guid id)
    {
        var r = await Api.DesactiverFamilleAsync(id);
        msgCls = r?.Succes == true ? "alert-success" : "alert-error";
        message = r?.Message;
        if (r?.Succes == true)
            await Load();
    }

    private static string GetLibelleCls(FamilleArticleDto f)
    {
        if (f.ParentId.HasValue)
            return "text-muted";
        return "font-bold";
    }
}
