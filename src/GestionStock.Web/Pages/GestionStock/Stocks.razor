@page "/stocks"
@attribute [Authorize]
@inject IApiService Api
@inject NavigationManager Nav
@inject ICurrencyService Devise
@inject IPrintService PrintService

<PageTitle>Documents de stock - GestionStock</PageTitle>

<div class="stocks-documents-page">
    <div class="page-header stocks-documents-page__header">
        <div>
            <h1 class="page-title">Documents de stock</h1>
            <p class="page-subtitle">Retrouvez les entrees, sorties, transferts et inventaires sous forme de documents avec entete et lignes.</p>
        </div>
        <div class="header-actions">
            <button class="btn-primary" @onclick="AllerNouveau">+ Nouveau document</button>
        </div>
    </div>

    <section class="surface-hero surface-hero--compact stocks-documents-hero">
        <div class="surface-hero-copy">
            <span class="surface-hero-eyebrow">Gestion documentaire</span>
            <h2>Le stock s'organise maintenant autour de vrais documents.</h2>
            <p>Chaque document regroupe son entete, ses lignes, son operateur, ses references et sa valorisation.</p>
        </div>
        <div class="surface-hero-pills">
            <span class="surface-pill">Entrees</span>
            <span class="surface-pill">Sorties</span>
            <span class="surface-pill">Transferts</span>
            <span class="surface-pill">Inventaires</span>
        </div>
    </section>

    <div class="stocks-documents-toolbar">
        <div class="stocks-type-tabs" role="tablist" aria-label="Types de documents stock">
            @foreach (var option in typeOptions)
            {
                <button type="button"
                        class="chip-filter @(selectedTypeFilter == option.Value ? "chip-filter--active" : null)"
                        @onclick="() => ChangerType(option.Value)">
                    @option.Label
                </button>
            }
        </div>
        <div class="toolbar">
            <div class="search-box">
                <span class="search-icon">🔍</span>
                <input class="search-input" type="text" placeholder="Numero, reference, article, motif..." @bind="recherche" @bind:event="oninput" />
            </div>
            <div class="toolbar-right">
                <span class="record-count">@DocumentsFiltres.Count() document(s)</span>
            </div>
        </div>
    </div>

    @if (chargement)
    {
        <div class="loading-state"><div class="spinner-lg"></div></div>
    }
    else if (!DocumentsFiltres.Any())
    {
        <div class="empty-state">Aucun document de stock trouve pour les criteres selectionnes.</div>
    }
    else
    {
        <div class="table-container stocks-documents-table">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>N° document</th>
                        <th>Type</th>
                        <th>Date</th>
                        <th>Reference</th>
                        <th class="text-right">Lignes</th>
                        <th class="text-right">Quantite</th>
                        <th class="text-right">Valeur</th>
                        <th>Articles</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var doc in DocumentsFiltres)
                    {
                        <tr class="stocks-documents-row">
                            <td>
                                <div class="cell-main"><code>@doc.Numero</code></div>
                                <div class="cell-sub">@FormatOperateur(doc.CreatedBy)</div>
                            </td>
                            <td><span class="badge @GetMvtBadgeCls(doc.TypeDocument)">@doc.TypeLibelle</span></td>
                            <td class="text-muted small">@doc.DateDocument.ToString("dd/MM/yyyy")</td>
                            <td class="text-muted small">@(string.IsNullOrWhiteSpace(doc.Reference) ? "—" : doc.Reference)</td>
                            <td class="text-right mono">@doc.NombreLignes</td>
                            <td class="text-right mono">@doc.QuantiteTotale</td>
                            <td class="text-right mono">@Montant(doc.ValeurTotale)</td>
                            <td class="text-muted small stocks-documents-articles">@FormatResumeArticles(doc.ResumeArticles)</td>
                            <td class="stocks-documents-actions">
                                <button type="button" class="btn-secondary" @onclick="() => Consulter(doc.Id)">Consulter</button>
                                <button type="button" class="btn-row-action btn-row-action--print" @onclick="() => ImprimerDocument(doc)">Imprimer</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private readonly List<(int Value, string Label)> typeOptions =
    [
        (0, "Tous"),
        (1, "Entrees"),
        (2, "Sorties"),
        (3, "Transferts"),
        (4, "Inventaires")
    ];

    private List<DocumentStockDto> documents = new();
    private ParametresDto? parametres;
    private string recherche = string.Empty;
    private bool chargement = true;
    private int selectedTypeFilter;

    private IEnumerable<DocumentStockDto> DocumentsFiltres =>
        documents.Where(d =>
            (selectedTypeFilter == 0 || d.TypeDocument == selectedTypeFilter) &&
            (string.IsNullOrWhiteSpace(recherche) ||
             d.Numero.Contains(recherche, StringComparison.OrdinalIgnoreCase) ||
             (d.Reference?.Contains(recherche, StringComparison.OrdinalIgnoreCase) ?? false) ||
             (d.Motif?.Contains(recherche, StringComparison.OrdinalIgnoreCase) ?? false) ||
             d.TypeLibelle.Contains(recherche, StringComparison.OrdinalIgnoreCase) ||
             d.CreatedBy.Contains(recherche, StringComparison.OrdinalIgnoreCase) ||
             d.ResumeArticles.Contains(recherche, StringComparison.OrdinalIgnoreCase) ||
             d.Lignes.Any(l =>
                 l.ArticleCode.Contains(recherche, StringComparison.OrdinalIgnoreCase) ||
                 l.Designation.Contains(recherche, StringComparison.OrdinalIgnoreCase) ||
                 (l.NumeroLot?.Contains(recherche, StringComparison.OrdinalIgnoreCase) ?? false) ||
                 (l.NumeroSerie?.Contains(recherche, StringComparison.OrdinalIgnoreCase) ?? false))))
        .OrderByDescending(d => d.DateDocument)
        .ThenByDescending(d => d.Numero);

    protected override async Task OnInitializedAsync()
    {
        await Devise.EnsureLoadedAsync();
        await Load();
    }

    private async Task Load()
    {
        chargement = true;
        var documentsTask = Api.GetDocumentsStockAsync(DateTime.Today.AddDays(-90), DateTime.Today.AddDays(1), null, null);
        var parametresTask = Api.GetParametresAsync();

        await Task.WhenAll(documentsTask, parametresTask);

        documents = (await documentsTask)?.ToList() ?? new();
        parametres = await parametresTask;
        chargement = false;
    }

    private void ChangerType(int type) => selectedTypeFilter = type;

    private async Task ImprimerDocument(DocumentStockDto doc)
    {
        parametres ??= await Api.GetParametresAsync() ?? new ParametresDto();
        await PrintService.PrintDocumentStockAsync(ToPrintDto(doc), parametres, Devise);
    }

    private void Consulter(Guid id) => Nav.NavigateTo($"/stocks/consultation/{id}");

    private DocumentStockPrintDto ToPrintDto(DocumentStockDto doc) =>
        new(
            string.IsNullOrWhiteSpace(doc.Reference) ? doc.Numero : doc.Reference!,
            doc.TypeLibelle,
            doc.DateDocument,
            doc.NombreLignes,
            doc.QuantiteTotale,
            doc.ValeurTotale,
            doc.CreatedBy,
            doc.Motif,
            doc.Lignes
                .OrderBy(l => l.Ordre)
                .Select(l => new DocumentStockPrintLineDto(
                    l.ArticleCode,
                    l.Designation,
                    l.EmplacementSourceCode ?? string.Empty,
                    l.EmplacementDestinationCode,
                    l.NumeroLot,
                    l.NumeroSerie,
                    l.Quantite,
                    l.ValeurUnitaire,
                    l.ValeurTotale,
                    l.Motif))
                .ToList());

    private static string FormatOperateur(string? createdBy)
    {
        if (string.IsNullOrWhiteSpace(createdBy))
            return "—";

        return createdBy.Length <= 18 ? createdBy : $"{createdBy[..18]}…";
    }

    private static string FormatResumeArticles(string? resume)
    {
        if (string.IsNullOrWhiteSpace(resume))
            return "—";

        return resume.Length <= 42 ? resume : $"{resume[..42]}…";
    }

    private void AllerNouveau() => Nav.NavigateTo("/stocks/nouveau");
    private void AllerSortie() => Nav.NavigateTo("/stocks/sortie");
    private void AllerTransfert() => Nav.NavigateTo("/stocks/transfert");
    private void AllerInventaire() => Nav.NavigateTo("/stocks/inventaire");

    private string Montant(decimal value) => Devise.FormatAmount(value);

    private string GetMvtBadgeCls(int type) => type switch
    {
        1 => "badge-green",
        2 => "badge-red",
        3 => "badge-blue",
        4 => "badge-amber",
        _ => "badge-gray"
    };
}
