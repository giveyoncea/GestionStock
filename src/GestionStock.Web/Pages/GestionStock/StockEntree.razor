@page "/stocks/entree"
@attribute [Authorize]
@inject IApiService Api
@inject NavigationManager Nav
@inject ICurrencyService Devise
@inject IJSRuntime JS
@implements IAsyncDisposable
<PageTitle>Entree de stock - GestionStock</PageTitle>

<HeadContent>
    <link rel="stylesheet" href="/css/stock-entree-window.css?v=20260403c" />
</HeadContent>

<div class="stock-entry-page">
    <div class="stock-entry-page__overlay"></div>
    <section id="stock-entry-window"
             class="stock-entry-window @(isMaximized ? "stock-entry-window--maximized workspace-window--maximized" : string.Empty) @(isMinimized ? "stock-entry-window--minimized" : string.Empty)"
             style="@GetWindowStyle()">
        <header id="stock-entry-header"
                class="stock-entry-window__header @(isMaximized ? string.Empty : "stock-entry-window__header--draggable")">
            <div class="stock-entry-window__heading">
                <div class="stock-entry-window__breadcrumb">Stocks / Nouveau document / Entree</div>
                <h1 class="stock-entry-window__title">Document d'entree de stock</h1>
                <p class="stock-entry-window__subtitle">Creez une vraie fiche d'entree avec une entete et plusieurs lignes de document.</p>
            </div>
            <div class="stock-entry-window__controls">
                <button type="button"
                        class="stock-window-btn"
                        title="Reduire"
                        aria-label="Reduire"
                        @onclick="BasculerReduction">
                    _
                </button>
                <button type="button"
                        class="stock-window-btn"
                        title="@(isMaximized ? "Restaurer" : "Agrandir")"
                        aria-label="@(isMaximized ? "Restaurer" : "Agrandir")"
                        @onclick="BasculerAgrandissement">
                    @(isMaximized ? "❐" : "□")
                </button>
                <button type="button"
                        class="stock-window-btn stock-window-btn--danger"
                        title="Fermer"
                        aria-label="Fermer"
                        @onclick="Fermer">
                    ×
                </button>
            </div>
        </header>
        <div class="stock-entry-window__body" style="display:@(isMinimized ? "none" : "block");">
                <section class="surface-hero surface-hero--compact stock-operation-hero">
                    <div class="surface-hero-copy">
                        <span class="surface-hero-eyebrow">Document d'entree</span>
                        <h2>Ajoutez plusieurs lignes dans une seule fiche pour garder une tracabilite propre.</h2>
                        <p>La reference, la date et le motif sont portes par le document. Chaque ligne precise ensuite l'article, l'emplacement et la valorisation.</p>
                    </div>
                    <div class="surface-hero-pills">
                        <span class="surface-pill">Entete</span>
                        <span class="surface-pill">Lignes</span>
                        <span class="surface-pill">Lots</span>
                        <span class="surface-pill">Series</span>
                    </div>
                </section>
                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <div class="@msgCls">@message</div>
                }
                @if (chargement)
                {
                    <div class="loading-state"><div class="spinner-lg"></div></div>
                }
                else
                {
                    <section class="editor-shell stock-document-entry-shell">
                        <div class="editor-card stock-document-entry-card">
                            <div class="editor-section">
                                <div class="form-section-title">Entete du document</div>
                                <div class="editor-grid">
                                    <div class="field-group">
                                        <label class="field-label">Date du document *</label>
                                        <input class="field-input" type="date" @bind="dateDocument" />
                                    </div>
                                    <div class="field-group editor-span-2">
                                        <label class="field-label">Reference *</label>
                                        <input class="field-input" @bind="reference" placeholder="ENT-2026-0001" />
                                    </div>
                                    <div class="field-group editor-span-3">
                                        <label class="field-label">Motif general</label>
                                        <input class="field-input" @bind="motifDocument" placeholder="Reception fournisseur, entree initiale, retour atelier..." />
                                    </div>
                                </div>
                            </div>
                            <div class="editor-section">
                                <div class="stock-document-entry-title-row">
                                    <div>
                                        <div class="form-section-title">Ajouter une ligne</div>
                                        <p class="stock-document-entry-help">Chaque ligne alimente le stock et sera reprise dans le document final.</p>
                                    </div>
                                </div>
                                <div class="editor-grid stock-document-entry-grid">
                                    <div class="field-group editor-span-2">
                                        <label class="field-label">Article *</label>
                                        <select class="field-input" @bind="draft.ArticleId" @bind:after="OnDraftArticleChanged">
                                            <option value="@Guid.Empty">Selectionner</option>
                                            @foreach (var article in articles)
                                            {
                                                <option value="@article.Id">[@article.Code] @article.Designation</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="field-group editor-span-2">
                                        <label class="field-label">Emplacement *</label>
                                        <select class="field-input" @bind="draft.EmplacementId">
                                            <option value="@Guid.Empty">Selectionner</option>
                                            @foreach (var e in emplacements)
                                            {
                                                <option value="@e.Id">[@e.Zone] @e.Code</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="field-group">
                                        <label class="field-label">Quantite *</label>
                                        <input class="field-input" type="number" min="1" @bind="draft.Quantite" disabled="@DraftArticleSerialise" />
                                    </div>
                                    <div class="field-group">
                                        <label class="field-label">@($"Prix unitaire ({Devise.Symbol})")</label>
                                        <input class="field-input" type="number" step="@Devise.AmountStep" min="0" @bind="draft.PrixUnitaire" />
                                    </div>
                                    <div class="field-group">
                                        <label class="field-label">No lot</label>
                                        <input class="field-input" @bind="draft.NumeroLot" />
                                    </div>
                                    @if (DraftArticleSerialise)
                                    {
                                        <div class="field-group">
                                            <label class="field-label">No serie *</label>
                                            <input class="field-input" @bind="draft.NumeroSerie" placeholder="SN-000001" />
                                        </div>
                                    }
                                    <div class="field-group editor-span-2">
                                        <label class="field-label">Motif de ligne</label>
                                        <input class="field-input" @bind="draft.Motif" placeholder="Optionnel si le motif general suffit" />
                                    </div>
                                </div>
                                <div class="stock-document-entry-line-actions">
                                    <button class="btn btn-secondary" @onclick="ReinitialiserDraft" type="button">Reinitialiser la ligne</button>
                                    <button class="btn btn-primary" @onclick="AjouterLigne" type="button">Ajouter la ligne</button>
                                </div>
                            </div>
                            <div class="editor-section">
                                <div class="stock-document-entry-title-row">
                                    <div>
                                        <div class="form-section-title">Lignes du document</div>
                                        <p class="stock-document-entry-help">@lignes.Count ligne(s) pretes a etre enregistrees.</p>
                                    </div>
                                    <div class="stock-document-entry-summary">
                                        <span><strong>@lignes.Sum(l => l.Quantite)</strong> unite(s)</span>
                                        <span><strong>@Devise.FormatAmount(lignes.Sum(l => l.Quantite * l.PrixUnitaire))</strong></span>
                                    </div>
                                </div>
                                @if (lignes.Count == 0)
                                {
                                    <div class="empty-state">Ajoutez au moins une ligne pour creer le document d'entree.</div>
                                }
                                else
                                {
                                    <div class="table-container">
                                        <table class="data-table">
                                            <thead>
                                                <tr>
                                                    <th>Article</th>
                                                    <th>Emplacement</th>
                                                    <th class="text-right">Quantite</th>
                                                    <th class="text-right">PU</th>
                                                    <th class="text-right">Total</th>
                                                    <th>Lot / Serie</th>
                                                    <th>Motif</th>
                                                    <th>Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var ligne in lignes.Select((value, index) => new { value, index }))
                                                {
                                                    <tr>
                                                        <td>
                                                            <div class="cell-main">@ligne.value.ArticleDesignation</div>
                                                            <div class="cell-sub"><code>@ligne.value.ArticleCode</code></div>
                                                        </td>
                                                        <td>@ligne.value.EmplacementCode</td>
                                                        <td class="text-right mono">@ligne.value.Quantite</td>
                                                        <td class="text-right mono">@Devise.FormatAmount(ligne.value.PrixUnitaire)</td>
                                                        <td class="text-right mono">@Devise.FormatAmount(ligne.value.Quantite * ligne.value.PrixUnitaire)</td>
                                                        <td class="text-muted small">@FormatLotSerie(ligne.value)</td>
                                                        <td class="text-muted small">@(string.IsNullOrWhiteSpace(ligne.value.Motif) ? "-" : ligne.value.Motif)</td>
                                                        <td class="text-right">
                                                            <button class="btn-row-action btn-row-action--danger" type="button" @onclick="() => SupprimerLigne(ligne.index)">Retirer</button>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </div>
                        <aside class="editor-side">
                            <div class="editor-side-card">
                                <h3>Reperes</h3>
                                <ul class="editor-hints">
                                    <li>La reference identifie le document complet, pas une ligne isolee.</li>
                                    <li>Un article sans suivi de stock ne doit pas etre ajoute ici.</li>
                                    <li>Pour un article serialise, la quantite est forcee a 1 et le numero de serie devient obligatoire.</li>
                                    <li>Le document apparaitra ensuite dans <strong>Stocks</strong> avec toutes ses lignes.</li>
                                </ul>
                            </div>
                        </aside>
                    </section>
                    <div class="editor-footer">
                        <div></div>
                        <div class="editor-footer-actions">
                            <button class="btn btn-secondary" @onclick="RetourListe" disabled="@saving">Annuler</button>
                            <button class="btn btn-primary" @onclick="EnregistrerDocument" disabled="@saving">@(saving ? "Enregistrement..." : "Enregistrer le document")</button>
                        </div>
                    </div>
                }
            </div>
    </section>
</div>
@code {
    private sealed class EntreeDraft
    {
        public Guid ArticleId { get; set; }
        public Guid EmplacementId { get; set; }
        public int Quantite { get; set; } = 1;
        public decimal PrixUnitaire { get; set; }
        public string? NumeroLot { get; set; }
        public string? NumeroSerie { get; set; }
        public string? Motif { get; set; }
    }
    private sealed class EntreeLineVm
    {
        public Guid ArticleId { get; init; }
        public string ArticleCode { get; init; } = string.Empty;
        public string ArticleDesignation { get; init; } = string.Empty;
        public Guid EmplacementId { get; init; }
        public string EmplacementCode { get; init; } = string.Empty;
        public int Quantite { get; init; }
        public decimal PrixUnitaire { get; init; }
        public string? NumeroLot { get; init; }
        public string? NumeroSerie { get; init; }
        public string? Motif { get; init; }
    }
    private readonly List<EntreeLineVm> lignes = new();
    private readonly EntreeDraft draft = new();
    private List<ArticleDto> articles = new();
    private List<EmplacementDto> emplacements = new();
    private bool chargement = true;
    private bool saving;
    private bool isMaximized;
    private bool isMinimized;
    private bool jsReady;
    private string? message;
    private string msgCls = "alert-success";
    private DateTime dateDocument = DateTime.Today;
    private string reference = $"ENT-{DateTime.Today:yyyyMMdd-HHmm}";
    private string? motifDocument;
    private ArticleDto? draftArticle;
    private IJSObjectReference? stockEntryWindowModule;
    private bool DraftArticleSerialise => draftArticle?.GestionNumeroDeSerie == true;
    protected override async Task OnInitializedAsync()
    {
        await Devise.EnsureLoadedAsync();
        await Charger();
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || jsReady)
            return;
        var module = await EnsureStockEntryWindowModuleAsync();
        await module.InvokeVoidAsync("initializeFloatingWindow", "stock-entry-window", "stock-entry-header");
        jsReady = true;
    }
    private async Task Charger()
    {
        chargement = true;
        var articlesTask = Api.GetArticlesAsync(1, 500, null, null);
        var emplacementsTask = Api.GetEmplacementsAsync();
        await Task.WhenAll(articlesTask, emplacementsTask);
        articles = ((await articlesTask)?.Items ?? Enumerable.Empty<ArticleDto>())
            .Where(a => !a.SansSuiviStock)
            .OrderBy(a => a.Designation)
            .ToList();
        emplacements = (await emplacementsTask) ?? new();
        chargement = false;
    }
    private void RetourListe() => Nav.NavigateTo("/stocks");
    private void Fermer() => Nav.NavigateTo("/stocks");

    private string GetWindowStyle()
    {
        if (isMaximized)
            return string.Empty;

        if (isMinimized)
            return "top: 90px; left: 260px; width: min(980px, calc(100vw - 120px));";

        return "top: 90px; left: 260px; width: min(1440px, calc(100vw - 320px)); height: min(920px, calc(100vh - 140px));";
    }
    private void BasculerReduction()
    {
        isMinimized = !isMinimized;
    }
    private async Task BasculerAgrandissement()
    {
        isMaximized = !isMaximized;
        if (isMaximized)
        {
            isMinimized = false;
        }
        if (stockEntryWindowModule is not null)
        {
            await stockEntryWindowModule.InvokeVoidAsync("setWindowMaximized", "stock-entry-window", isMaximized);
        }
    }
    private Task OnDraftArticleChanged()
    {
        draftArticle = articles.FirstOrDefault(a => a.Id == draft.ArticleId);
        if (DraftArticleSerialise)
        {
            draft.Quantite = 1;
        }
        else
        {
            draft.NumeroSerie = null;
        }
        return Task.CompletedTask;
    }
    private void ReinitialiserDraft()
    {
        draft.ArticleId = Guid.Empty;
        draft.EmplacementId = Guid.Empty;
        draft.Quantite = 1;
        draft.PrixUnitaire = 0;
        draft.NumeroLot = null;
        draft.NumeroSerie = null;
        draft.Motif = null;
        draftArticle = null;
        message = null;
    }
    private Task AjouterLigne()
    {
        var article = articles.FirstOrDefault(a => a.Id == draft.ArticleId);
        var emplacement = emplacements.FirstOrDefault(e => e.Id == draft.EmplacementId);
        if (article is null || emplacement is null)
        {
            msgCls = "alert-error";
            message = "Selectionnez un article et un emplacement valides avant d'ajouter la ligne.";
            return Task.CompletedTask;
        }
        if (draft.Quantite <= 0)
        {
            msgCls = "alert-error";
            message = "La quantite de la ligne doit etre superieure a zero.";
            return Task.CompletedTask;
        }
        if (article.GestionNumeroDeSerie)
        {
            if (draft.Quantite != 1)
            {
                msgCls = "alert-error";
                message = "Un article serialise doit etre saisi avec une quantite egale a 1.";
                return Task.CompletedTask;
            }
            if (string.IsNullOrWhiteSpace(draft.NumeroSerie))
            {
                msgCls = "alert-error";
                message = "Le numero de serie est obligatoire pour cet article.";
                return Task.CompletedTask;
            }
        }
        lignes.Add(new EntreeLineVm
        {
            ArticleId = article.Id,
            ArticleCode = article.Code,
            ArticleDesignation = article.Designation,
            EmplacementId = emplacement.Id,
            EmplacementCode = $"[{emplacement.Zone}] {emplacement.Code}",
            Quantite = draft.Quantite,
            PrixUnitaire = draft.PrixUnitaire,
            NumeroLot = draft.NumeroLot,
            NumeroSerie = draft.NumeroSerie,
            Motif = draft.Motif
        });
        msgCls = "alert-success";
        message = "Ligne ajoutee au document.";
        ReinitialiserDraft();
        return Task.CompletedTask;
    }
    private void SupprimerLigne(int index)
    {
        if (index < 0 || index >= lignes.Count)
            return;
        lignes.RemoveAt(index);
        message = lignes.Count == 0 ? "La ligne a ete retiree du document." : "Ligne retiree du document.";
        msgCls = "alert-success";
    }
    private async Task EnregistrerDocument()
    {
        if (string.IsNullOrWhiteSpace(reference))
        {
            msgCls = "alert-error";
            message = "La reference du document est obligatoire.";
            return;
        }
        if (lignes.Count == 0)
        {
            msgCls = "alert-error";
            message = "Ajoutez au moins une ligne avant d'enregistrer le document.";
            return;
        }
        saving = true;
        var result = await Api.CreerDocumentEntreeStockAsync(new DocumentEntreeStockRequest
        {
            DateDocument = dateDocument,
            Reference = reference,
            Motif = motifDocument,
            Lignes = lignes.Select(l => new LigneDocumentEntreeStockRequest
            {
                ArticleId = l.ArticleId,
                EmplacementId = l.EmplacementId,
                Quantite = l.Quantite,
                PrixUnitaire = l.PrixUnitaire,
                NumeroLot = l.NumeroLot,
                NumeroSerie = l.NumeroSerie,
                Motif = l.Motif
            }).ToList()
        });
        saving = false;
        msgCls = result?.Succes == true ? "alert-success" : "alert-error";
        message = result?.Message;
        if (result?.Succes == true)
            Nav.NavigateTo("/stocks");
    }
    private static string FormatLotSerie(EntreeLineVm ligne)
    {
        if (!string.IsNullOrWhiteSpace(ligne.NumeroSerie))
            return $"Serie: {ligne.NumeroSerie}";
        if (!string.IsNullOrWhiteSpace(ligne.NumeroLot))
            return $"Lot: {ligne.NumeroLot}";
        return "-";
    }
    private async Task<IJSObjectReference> EnsureStockEntryWindowModuleAsync()
    {
        stockEntryWindowModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "/js/windowing.js");
        return stockEntryWindowModule;
    }
    public async ValueTask DisposeAsync()
    {
        if (stockEntryWindowModule is not null)
        {
            try
            {
                await stockEntryWindowModule.DisposeAsync();
            }
            catch
            {
            }
        }
    }
}

