@code {
    private string activeTab = "alertes";
    private bool chargement = true, chargementMvt = false, saving = false;
    private string? message;
    private string msgCls = "alert-success";
    private int pageSize = 10;
    private readonly int[] pageSizeOptions = [10, 20, 50, 100];
    private int currentPageAlertes = 1;
    private int currentPageLots = 1;

    // Alertes
    private List<AlertePeremptionDto> alertes = new();
    private int joursAvance = 30;
    private IEnumerable<AlertePeremptionDto> AlertesPage => alertes
        .Skip((currentPageAlertes - 1) * pageSize)
        .Take(pageSize);
    private int TotalPagesAlertes => Math.Max(1, (int)Math.Ceiling(alertes.Count / (double)pageSize));
    private string PaginationResumeAlertes
    {
        get
        {
            if (!alertes.Any()) return "0-0 sur 0";
            var start = (currentPageAlertes - 1) * pageSize + 1;
            var end = Math.Min(currentPageAlertes * pageSize, alertes.Count);
            return $"{start}-{end} sur {alertes.Count}";
        }
    }

    // Lots
    private List<LotTracabiliteDto> lots = new();
    private string rechercheLot = "";
    private string filtreStatutLot = "";
    private IEnumerable<LotTracabiliteDto> LotsFiltres =>
        string.IsNullOrWhiteSpace(rechercheLot) ? lots
        : lots.Where(l => l.NumeroLot.Contains(rechercheLot, StringComparison.OrdinalIgnoreCase) ||
                          l.ArticleCode.Contains(rechercheLot, StringComparison.OrdinalIgnoreCase) ||
                          l.ArticleDesignation.Contains(rechercheLot, StringComparison.OrdinalIgnoreCase));
    private IEnumerable<LotTracabiliteDto> LotsPage => LotsFiltres
        .Skip((currentPageLots - 1) * pageSize)
        .Take(pageSize);
    private int TotalPagesLots => Math.Max(1, (int)Math.Ceiling(LotsFiltres.Count() / (double)pageSize));
    private string PaginationResumeLots
    {
        get
        {
            var total = LotsFiltres.Count();
            if (total == 0) return "0-0 sur 0";
            var start = (currentPageLots - 1) * pageSize + 1;
            var end = Math.Min(currentPageLots * pageSize, total);
            return $"{start}-{end} sur {total}";
        }
    }

    // CrÃ©ation lot
    private bool showCreerLot = false;
    private List<ArticleDto> articlesGestionLot = new();
    private string lotArticleId = "";
    private string lotNumero = "", lotNumeroSerie = "", lotCertificat = "";
    private DateTime lotDateReception = DateTime.Today;
    private DateTime? lotDateFabrication, lotDatePeremption;
    private int lotQuantite = 1;

    // DÃ©tail lot
    private LotTracabiliteDto? lotSelectionne;
    private bool showMouvementsLot = false;
    private bool showStatutLot = false;
    private List<MouvementTracabiliteDto> mouvementsLot = new();
    private int nouveauStatut = 1;

    protected override async Task OnInitializedAsync()
    {
        await Devise.EnsureLoadedAsync();
        await ChargerAlertes();
        var arts = await Api.GetArticlesAsync(1, 200, null, null);
        articlesGestionLot = arts?.Items.ToList() ?? new();
    }

    private async Task SetTabAlertes() => await SetTab("alertes");
    private async Task SetTabLots() => await SetTab("lots");

    private async Task SetTab(string tab)
    {
        activeTab = tab;
        if (tab == "alertes") await ChargerAlertes();
        else await ChargerLots();
    }

    private async Task ChargerAlertes()
    {
        chargement = true;
        alertes = await Api.GetAlertesPeremptionAsync(joursAvance) ?? new();
        AssurerPaginationAlertesValide();
        chargement = false;
    }

    private async Task ChargerLots()
    {
        chargement = true;
        lots = await Api.GetLotsAsync() ?? new();
        AssurerPaginationLotsValide();
        chargement = false;
    }

    private void ReinitialiserPaginationLots()
    {
        currentPageLots = 1;
    }

    private void ChangerTaillePageTracabilite()
    {
        currentPageAlertes = 1;
        currentPageLots = 1;
    }

    private void PagePrecedenteAlertes()
    {
        if (currentPageAlertes > 1)
            currentPageAlertes--;
    }

    private void PageSuivanteAlertes()
    {
        if (currentPageAlertes < TotalPagesAlertes)
            currentPageAlertes++;
    }

    private void PagePrecedenteLots()
    {
        if (currentPageLots > 1)
            currentPageLots--;
    }

    private void PageSuivanteLots()
    {
        if (currentPageLots < TotalPagesLots)
            currentPageLots++;
    }

    private void AssurerPaginationAlertesValide()
    {
        if (currentPageAlertes > TotalPagesAlertes)
            currentPageAlertes = TotalPagesAlertes;
    }

    private void AssurerPaginationLotsValide()
    {
        if (currentPageLots > TotalPagesLots)
            currentPageLots = TotalPagesLots;
    }

    private void OuvrirCreationLot()
    {
        lotArticleId = ""; lotNumero = ""; lotNumeroSerie = ""; lotCertificat = "";
        lotDateReception = DateTime.Today; lotDateFabrication = null; lotDatePeremption = null;
        lotQuantite = 1;
        showCreerLot = true;
    }

    private async Task EnregistrerLot()
    {
        if (!Guid.TryParse(lotArticleId, out var aid) || string.IsNullOrWhiteSpace(lotNumero) || lotQuantite <= 0)
        {
            message = "Article, NÂ° lot et quantitÃ© obligatoires.";
            msgCls = "alert-error";
            return;
        }
        saving = true;
        var r = await Api.CreerLotAsync(new LotRequest
        {
            ArticleId = aid, NumeroLot = lotNumero, Quantite = lotQuantite,
            DateReception = lotDateReception,
            DateFabrication = lotDateFabrication,
            DatePeremption = lotDatePeremption,
            NumeroSerie = string.IsNullOrWhiteSpace(lotNumeroSerie) ? null : lotNumeroSerie,
            CertifiqueQualite = string.IsNullOrWhiteSpace(lotCertificat) ? null : lotCertificat
        });
        saving = false;
        msgCls = r?.Succes == true ? "alert-success" : "alert-error";
        message = r?.Message;
        if (r?.Succes == true) { showCreerLot = false; await ChargerLots(); activeTab = "lots"; }
    }

    private async Task OuvrirMouvementsLot(LotTracabiliteDto lot)
    {
        lotSelectionne = lot;
        showMouvementsLot = true;
        chargementMvt = true;
        mouvementsLot = await Api.GetMouvementsLotAsync(lot.Id) ?? new();
        chargementMvt = false;
    }

    private void OuvrirStatutLot(LotTracabiliteDto lot)
    {
        lotSelectionne = lot;
        nouveauStatut = lot.Statut;
        showStatutLot = true;
    }

    private async Task AppliquerStatut()
    {
        if (lotSelectionne == null) return;
        saving = true;
        var r = await Api.ModifierStatutLotAsync(lotSelectionne.Id, nouveauStatut);
        saving = false;
        msgCls = r?.Succes == true ? "alert-success" : "alert-error";
        message = r?.Message;
        if (r?.Succes == true) { showStatutLot = false; await ChargerLots(); }
    }

