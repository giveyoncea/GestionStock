@* â”€â”€â”€ ONGLET ALERTES PÃ‰REMPTION â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ *@
@if (activeTab == "alertes")
{
    <div class="toolbar">
        <div class="toolbar-filters">
            <label class="field-label" style="margin:0">Horizon :</label>
            <select class="field-input" @bind="joursAvance" @bind:after="ChargerAlertes">
                <option value="7">7 jours</option>
                <option value="15">15 jours</option>
                <option value="30">30 jours</option>
                <option value="60">60 jours</option>
                <option value="90">90 jours</option>
            </select>
        </div>
        <div class="toolbar-right">
            <select class="field-input ventes-page-size" @bind="pageSize" @bind:after="ChangerTaillePageTracabilite">
                @foreach (var size in pageSizeOptions)
                {
                    <option value="@size">@size / page</option>
                }
            </select>
            <span class="record-count">@alertes.Count alerte(s)</span>
        </div>
    </div>

    @if (chargement) { <div class="loading-state"><div class="spinner-lg"></div></div> }
    else
    {
        @if (!alertes.Any())
        {
            <div class="empty-state">âœ“ Aucune alerte de pÃ©remption sur les @joursAvance prochains jours.</div>
        }
        else
        {
            <div class="table-container">
                <table class="data-table">
                    <thead><tr>
                        <th>Article</th><th>NÂ° Lot</th><th>Date pÃ©remption</th>
                        <th class="text-right">QtÃ© restante</th><th>Jours restants</th><th>Statut</th>
                    </tr></thead>
                    <tbody>
                    @foreach (var a in AlertesPage)
                    {
                        <tr class="@(a.Critique ? "row-danger" : "row-warn")">
                            <td>
                                <div class="cell-main">@a.ArticleDesignation</div>
                                <div class="cell-sub"><code>@a.ArticleCode</code></div>
                            </td>
                            <td><code>@a.NumeroLot</code></td>
                            <td>@a.DatePeremption.ToString("dd/MM/yyyy")</td>
                            <td class="text-right mono">@a.QuantiteRestante</td>
                            <td>
                                <span class="badge @(a.Critique ? "badge-red" : "badge-amber")">
                                    @(a.JoursRestants <= 0 ? "PÃ‰RIMÃ‰" : $"J-{a.JoursRestants}")
                                </span>
                            </td>
                            <td><span class="badge badge-amber">@GetStatutLot(a.Statut)</span></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
            <div class="ventes-table-footer">
                <span class="page-info">@PaginationResumeAlertes</span>
                <div class="pager-controls">
                    <button class="btn-page" @onclick="PagePrecedenteAlertes" disabled="@(currentPageAlertes <= 1)">Précédent</button>
                    <span class="pager-indicator">Page @currentPageAlertes / @TotalPagesAlertes</span>
                    <button class="btn-page" @onclick="PageSuivanteAlertes" disabled="@(currentPageAlertes >= TotalPagesAlertes)">Suivant</button>
                </div>
            </div>
        }
    }
}

