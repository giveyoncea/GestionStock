@page "/articles"
@attribute [Authorize]
@inject IApiService Api
@inject NavigationManager Nav

<PageTitle>Articles - GestionStock</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Articles</h1>
        <p class="page-subtitle">Pilotez votre catalogue, reperez plus vite les references sensibles et gardez une lecture simple des niveaux de stock.</p>
    </div>
    <button class="btn btn-primary" @onclick="AllerCreation">+ Nouvel article</button>
</div>

<section class="surface-hero surface-hero--compact">
    <div class="surface-hero-copy">
        <span class="surface-hero-eyebrow">Catalogue produit</span>
        <h2>Une vue plus lisible des references, familles et modes de suivi</h2>
        <p>Les informations cles sont mieux regroupees pour faciliter la consultation, la creation et la maintenance des articles, y compris les prestations sans stock.</p>
    </div>
    <div class="surface-hero-pills">
        <span class="surface-pill">References</span>
        <span class="surface-pill">Familles</span>
        <span class="surface-pill">Seuils</span>
        <span class="surface-pill">Disponibilites</span>
    </div>
</section>

<div class="toolbar">
    <div class="search-box">
        <span class="search-icon">Rech.</span>
        <input class="search-input" type="text" placeholder="Code, designation..."
               @bind="recherche" @bind:event="oninput" @onkeyup="OnKey" />
    </div>
    <div class="toolbar-right">
        <label class="ventes-page-size">
            <span>Lignes par page</span>
            <select @bind="pageSize" @bind:after="ChangerTaillePage">
                @foreach (var option in pageSizeOptions)
                {
                    <option value="@option">@option</option>
                }
            </select>
        </label>
        <span class="record-count">@total article(s)</span>
    </div>
</div>

@if (chargement)
{
    <div class="loading-state"><div class="spinner-lg"></div></div>
}
else
{
    <div class="table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Designation</th>
                    <th>Categorie / Famille</th>
                    <th>Suivi</th>
                    <th class="text-right">Seuil</th>
                    <th class="text-right">Stock min</th>
                    <th class="text-right">Stock max</th>
                    <th class="text-right">En stock</th>
                    <th>Etat</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var art in articles)
                {
                    <tr class="@GetRowCls(art)">
                        <td><code>@art.Code</code></td>
                        <td>
                            <div class="cell-main">@art.Designation</div>
                            @if (!string.IsNullOrEmpty(art.FournisseurNom))
                            {
                                <div class="cell-sub text-muted">@art.FournisseurNom</div>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(art.Categorie))
                            {
                                <span class="tag-cat">@art.Categorie</span>
                            }
                            @if (!string.IsNullOrEmpty(art.FamilleArticle))
                            {
                                <div class="cell-sub text-muted">@art.FamilleArticle</div>
                            }
                        </td>
                        <td>
                            <span class="badge @(art.SansSuiviStock ? "badge-gray" : "badge-blue")">
                                @(art.SansSuiviStock ? "Sans suivi" : "Avec suivi")
                            </span>
                        </td>
                        <td class="text-right mono">@(art.SansSuiviStock ? "-" : art.SeuilAlerte)</td>
                        <td class="text-right mono">@(art.SansSuiviStock ? "-" : art.StockMinimum)</td>
                        <td class="text-right mono text-muted">@(art.SansSuiviStock ? "-" : art.StockMaximum == 0 ? "inf" : art.StockMaximum.ToString())</td>
                        <td class="text-right mono @GetQtyCls(art)">@GetStockDisplay(art)</td>
                        <td><span class="badge @GetStatutCls(art)">@GetStatutLib(art)</span></td>
                        <td class="actions-cell">
                            <div class="row-actions">
                                <button class="btn-row-action btn-row-action--primary" title="Modifier" @onclick="() => AllerModification(art.Id)">Modifier</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="ventes-table-footer">
        <span class="page-info">@PaginationResume</span>
        <div class="pager-controls">
            <button class="btn-page" disabled="@(currentPage <= 1)" @onclick="() => ChangePage(currentPage - 1)">Precedent</button>
            <span class="pager-indicator">Page @currentPage / @totalPages</span>
            <button class="btn-page" disabled="@(currentPage >= totalPages)" @onclick="() => ChangePage(currentPage + 1)">Suivant</button>
        </div>
    </div>
}

@code {
    private List<ArticleDto> articles = new();
    private int currentPage = 1;
    private int pageSize = 20;
    private int totalPages = 1;
    private int total;
    private bool chargement = true;
    private string recherche = "";
    private System.Threading.Timer? _timer;
    private readonly int[] pageSizeOptions = [10, 20, 50, 100];

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private void OnKey(KeyboardEventArgs _)
    {
        _timer?.Dispose();
        _timer = new System.Threading.Timer(async _ =>
            await InvokeAsync(async () =>
            {
                currentPage = 1;
                await Load();
                StateHasChanged();
            }),
            null,
            400,
            System.Threading.Timeout.Infinite);
    }

    private async Task Load()
    {
        chargement = true;
        var r = await Api.GetArticlesAsync(currentPage, pageSize, recherche, null);
        articles = r?.Items.ToList() ?? new();
        total = r?.TotalCount ?? 0;
        totalPages = r?.TotalPages ?? 1;
        chargement = false;
    }

    private async Task ChangePage(int p)
    {
        currentPage = p;
        await Load();
    }

    private async Task ChangerTaillePage()
    {
        currentPage = 1;
        await Load();
    }

    private void AllerCreation()
        => Nav.NavigateTo("/articles/nouveau");

    private void AllerModification(Guid id)
        => Nav.NavigateTo($"/articles/modifier/{id}");

    private string GetRowCls(ArticleDto a) =>
        a.SansSuiviStock ? string.Empty : a.EstEnRupture ? "row-danger" : a.EstEnAlerte ? "row-warn" : string.Empty;

    private string GetQtyCls(ArticleDto a) =>
        a.SansSuiviStock ? "text-muted mono" : a.EstEnRupture ? "text-danger mono" : a.EstEnAlerte ? "text-warn mono" : "mono";

    private string GetStatutLib(ArticleDto a) =>
        a.SansSuiviStock ? "Sans suivi" : a.EstEnRupture ? "Rupture" : a.EstEnAlerte ? "Alerte" : "OK";

    private string GetStatutCls(ArticleDto a) =>
        a.SansSuiviStock ? "badge-gray" : a.EstEnRupture ? "badge-red" : a.EstEnAlerte ? "badge-amber" : "badge-green";

    private string GetStockDisplay(ArticleDto a)
        => a.SansSuiviStock ? "-" : a.QuantiteTotale.ToString();

    private string PaginationResume
    {
        get
        {
            if (total == 0)
            {
                return "0 article";
            }

            var debut = ((currentPage - 1) * pageSize) + 1;
            var fin = Math.Min(currentPage * pageSize, total);
            return $"{debut}-{fin} sur {total}";
        }
    }
}
