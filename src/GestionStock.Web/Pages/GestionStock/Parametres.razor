        "Ventes" => cpt.JournalVentesLibelle, "Achats" => cpt.JournalAchatsLibelle,
        "Banque" => cpt.JournalBanqueLibelle, "Caisse" => cpt.JournalCaisseLibelle,
        "Op. diverses" => cpt.JournalODLibelle, "A nouveaux" => cpt.JournalANouveauxLibelle,
