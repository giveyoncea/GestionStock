        "Ventes" => cpt.JournalVentes, "Achats" => cpt.JournalAchats,
        "Banque" => cpt.JournalBanque, "Caisse" => cpt.JournalCaisse,
        "Op. diverses" => cpt.JournalOD, "A nouveaux" => cpt.JournalANouveaux,
