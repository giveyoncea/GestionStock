    private string prefixeCA = "CA", prefixeArt = "ART", prefixeLot = "LOT", prefixeInv = "INV";
    private string banque = "", iban = "", bic = "";
    private ComptabiliteDto cpt = new();

    private ParametresDto? _snapshot;

    protected override async Task OnInitializedAsync()
    {
        chargement = true;
        var p = await Api.GetParametresAsync();
        if (p != null) ApplyFromDto(p);
        _snapshot = BuildDto();
        cpt = await Api.GetComptabiliteAsync() ?? new();
        chargement = false;
    }

    private void ApplyFromDto(ParametresDto p)
    {
        raisonSociale = p.RaisonSociale; siret = p.Siret; numTVA = p.NumTVA;
        telephone = p.Telephone; email = p.Email; siteWeb = p.SiteWeb;
        formeJuridique = p.FormeJuridique; adresse = p.Adresse;
        codePostal = p.CodePostal; ville = p.Ville; region = p.Region; pays = p.Pays;
        methodeValorisation = p.MethodeValorisation; gabaritInterface = p.GabaritInterface; devise = p.Devise;
        logoEntreprise = p.LogoEntreprise; formatImpressionDocuments = p.FormatImpressionDocuments;
        formatImpressionRecus = p.FormatImpressionRecus;
        formatPapierDocuments = p.FormatPapierDocuments;
        imprimanteDocumentsDefaut = p.ImprimanteDocumentsDefaut;
        formatPapierRecus = p.FormatPapierRecus;
        imprimanteRecusDefaut = p.ImprimanteRecusDefaut;
        symboleDevise = p.SymboleDevise; nombreDecimalesMontant = p.NombreDecimalesMontant;
        nombreDecimalesQuantite = p.NombreDecimalesQuantite;
        tauxTVA = p.TauxTVA; delaiAlerteDLUO = p.DelaiAlerteDLUO;
        autoriserStockNegatif = p.AutoriserStockNegatif;
        prefixeCA = p.PrefixeCA; prefixeArt = p.PrefixeArt;
        prefixeLot = p.PrefixeLot; prefixeInv = p.PrefixeInv;
        banque = p.Banque; iban = p.Iban; bic = p.Bic; delaiPaiement = p.DelaiPaiement;
        if (p.UpdatedAt.HasValue)
            lastSave = p.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm");
    }

    private ParametresDto BuildDto() => new()
    {
        RaisonSociale = raisonSociale, Siret = siret, NumTVA = numTVA,
        Telephone = telephone, Email = email, SiteWeb = siteWeb,
        FormeJuridique = formeJuridique, Adresse = adresse,
        CodePostal = codePostal, Ville = ville, Region = region, Pays = pays,
        MethodeValorisation = methodeValorisation, GabaritInterface = gabaritInterface, Devise = devise,
        LogoEntreprise = logoEntreprise,
        FormatImpressionDocuments = formatImpressionDocuments,
        FormatImpressionRecus = formatImpressionRecus,
        FormatPapierDocuments = formatPapierDocuments,
        ImprimanteDocumentsDefaut = imprimanteDocumentsDefaut,
        FormatPapierRecus = formatPapierRecus,
        ImprimanteRecusDefaut = imprimanteRecusDefaut,
        SymboleDevise = symboleDevise,
        NombreDecimalesMontant = nombreDecimalesMontant,
        NombreDecimalesQuantite = nombreDecimalesQuantite,
        TauxTVA = tauxTVA, DelaiAlerteDLUO = delaiAlerteDLUO,
        AutoriserStockNegatif = autoriserStockNegatif,
        PrefixeCA = prefixeCA, PrefixeArt = prefixeArt,
        PrefixeLot = prefixeLot, PrefixeInv = prefixeInv,
        Banque = banque, Iban = iban, Bic = bic, DelaiPaiement = delaiPaiement
    };

    private async Task Sauvegarder()
    {
        if (string.IsNullOrWhiteSpace(raisonSociale))
        {
            msgCls = "alert-error";
            message = "La raison sociale est obligatoire.";
            return;
        }
        saving = true;
        savingLabel = "Enregistrement...";
        var r = await Api.SauvegarderParametresAsync(BuildDto());
        // Sauvegarder aussi les parametres comptables
        await Api.SauvegarderComptabiliteAsync(cpt);
        saving = false;
        savingLabel = "Enregistrer les paramètres";
        msgCls = r?.Succes == true ? "alert-success" : "alert-error";
        message = r?.Message;
        if (r?.Succes == true)
        {
            await Devise.RefreshAsync();
            await Theme.RefreshAsync();
            _snapshot = BuildDto();
            var updated = await Api.GetParametresAsync();
            if (updated?.UpdatedAt.HasValue == true)
                lastSave = updated.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm");
        }
    }

    private async Task ChargerLogo(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null)
            return;

        if (!file.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
        {
            msgCls = "alert-error";
            message = "Le logo doit etre une image.";
            return;
        }

        await using var stream = file.OpenReadStream(2 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        logoEntreprise = $"data:{file.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
    }

    private void SupprimerLogo()
    {
        logoEntreprise = string.Empty;
    }

