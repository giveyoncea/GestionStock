@* â”€â”€â”€ Render helpers â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ *@
@* â”€â”€â”€ MODAL ACOMPTE CLIENT â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ *@
@if (showCreationAcompte)
{
    <div class="modal-overlay" @onclick="() => showCreationAcompte = false">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <h2>Nouvel acompte client</h2>
                <button class="btn-close" @onclick="() => showCreationAcompte = false">×</button>
            </div>
            <div class="modal-body">
                <div class="form-grid">
                    <div class="field-group col-span-2">
                        <label class="field-label">Client *</label>
                        <select class="field-input" @bind="aTiersId">
                            <option value="">- Sélectionner -</option>
                            @foreach (var c in clients)
                            { <option value="@c.Id">@c.RaisonSociale</option> }
                        </select>
                    </div>
                    <div class="field-group">
                        <label class="field-label">Montant *</label>
                        <input class="field-input" type="number" step="0.01" @bind="aMontant" />
                    </div>
                    <div class="field-group">
                        <label class="field-label">Mode paiement</label>
                        <select class="field-input" @bind="aMode">
                            @foreach (var m in Modes) { <option value="@m.Id">@m.Libelle</option> }
                        </select>
                    </div>
                    <div class="field-group">
                        <label class="field-label">Date</label>
                        <input class="field-input" type="date" @bind="aDate" />
                    </div>
                    <div class="field-group">
                        <label class="field-label">Référence</label>
                        <input class="field-input" @bind="aRef" placeholder="N° chèque, virement..." />
                    </div>
                    <div class="field-group col-span-2">
                        <label class="field-label">Notes</label>
                        <textarea class="field-input" rows="2" @bind="aNotes"></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="() => showCreationAcompte = false">Annuler</button>
                <button class="btn-primary" @onclick="() => CreerAcompte(estClient: true)" disabled="@saving">
                    @(saving ? "Enregistrement..." : "Enregistrer")
                </button>
            </div>
        </div>
    </div>
}

