@if (onglet == "regl-clients")
{
    <div class="toolbar" style="margin-top:12px">
        <div class="toolbar-filters">
            <select class="field-input" style="width:160px" @bind="filtreMode" @bind:after="ChargerReglClients">
                <option value="0">Tous modes</option>
                @foreach (var m in Modes) { <option value="@m.Id">@m.Libelle</option> }
            </select>
        </div>
        <div class="toolbar-right">
            <select class="field-input ventes-page-size" @bind="pageSize" @bind:after="ChangerTaillePageReglements">
                @foreach (var size in pageSizeOptions)
                {
                    <option value="@size">@size / page</option>
                }
            </select>
            <span class="record-count">@reglClients.Count encaissement(s)</span>
            <span class="record-count" style="font-weight:700;color:var(--col-green)">
                Total : @reglClients.Sum(r => r.Montant).ToString("N2") F
            </span>
        </div>
    </div>
    @RenderTableReglements(ReglClientsPage, chargementRC)
    <div class="ventes-table-footer">
        <span class="page-info">@PaginationResumeReglClients</span>
        <div class="pager-controls">
            <button class="btn-page" @onclick="PagePrecedenteReglClients" disabled="@(currentPageReglClients <= 1)">Précédent</button>
            <span class="pager-indicator">Page @currentPageReglClients / @TotalPagesReglClients</span>
            <button class="btn-page" @onclick="PageSuivanteReglClients" disabled="@(currentPageReglClients >= TotalPagesReglClients)">Suivant</button>
        </div>
    </div>
}

