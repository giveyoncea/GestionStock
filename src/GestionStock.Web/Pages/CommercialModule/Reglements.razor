    private async Task ChargerReferentielsAsync()
    {
        await Task.WhenAll(
            Task.Run(async () => clients = await Api.GetClientsAsync() ?? new()),
            Task.Run(async () =>
            {
                var r = await Api.GetFournisseursAsync(1, 500);
                fournisseurs = r?.Items.ToList() ?? new();
            })
        );
    }

    private async Task SynchroniserOngletDepuisRouteAsync()
    {
        var route = Nav.ToBaseRelativePath(Nav.Uri).Trim('/').ToLowerInvariant();
        var prochainOnglet = route switch
        {
            "commercial/reglements/decaissements" or "reglements/decaissements" => "regl-fourn",
            "commercial/reglements/acomptes-clients" or "reglements/acomptes-clients" => "acomptes-clients",
            "commercial/reglements/acomptes-fournisseurs" or "reglements/acomptes-fournisseurs" => "acomptes-fourn",
            _ => "regl-clients"
        };

        onglet = prochainOnglet;

        switch (prochainOnglet)
        {
            case "regl-fourn":
                if (!reglFourn.Any())
                    await ChargerReglFourn();
                break;
            case "acomptes-clients":
                if (!acomptesClients.Any())
                    await ChargerAcomptesClients();
                break;
            case "acomptes-fourn":
                if (!acomptesFourn.Any())
                    await ChargerAcomptesFourn();
                break;
            default:
                if (!reglClients.Any())
                    await ChargerReglClients();
                break;
        }
