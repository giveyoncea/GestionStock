    private string ConstruireResumePagination(int page, int total)
    {
        if (total == 0) return "0-0 sur 0";
        var start = (page - 1) * pageSize + 1;
        var end = Math.Min(page * pageSize, total);
        return $"{start}-{end} sur {total}";
    }

