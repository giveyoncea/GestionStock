@inject ICurrencyService CurrencyService
@inject NavigationManager Nav

<PageTitle>Règlements & acomptes - GestionStock</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Règlements & acomptes</h1>
        <p class="page-date">Encaissements clients · Décaissements fournisseurs</p>
    </div>
    <div class="header-actions">
        @if (onglet == "acomptes-clients")
        {
            <button class="btn-primary" @onclick="OuvrirCreationAcompte">+ Acompte client</button>
        }
        else if (onglet == "acomptes-fourn")
        {
            <button class="btn-primary" @onclick="OuvrirCreationAcompteFourn">+ Acompte fournisseur</button>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(message)) { <div class="@msgCls">@message</div> }

