    private async Task CreerAcompte(bool estClient)
    {
        if (!Guid.TryParse(aTiersId, out var tiersGuid) || aMontant <= 0)
        {
            message="Tiers et montant obligatoires."; msgCls="alert-error"; return;
        }
        saving=true;
        var dto = new AcompteRequest {
            Montant=aMontant, ModeReglement=aMode, DateAcompte=aDate,
            Reference=string.IsNullOrWhiteSpace(aRef)?null:aRef,
            Notes=string.IsNullOrWhiteSpace(aNotes)?null:aNotes
        };
        if (estClient) dto.ClientId=tiersGuid; else dto.FournisseurId=tiersGuid;
        var r = await Api.CreerAcompteAsync(dto);
        saving=false;
        msgCls=r?.Succes==true?"alert-success":"alert-error"; message=r?.Message;
        if (r?.Succes==true)
        {
            showCreationAcompte=false; showCreationAcompteFourn=false;
