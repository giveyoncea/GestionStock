@* â”€â”€â”€ MODAL IMPUTATION â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ *@
@if (showImputation && acompteAImputer != null)
{
    <div class="modal-overlay" @onclick="() => showImputation = false">
        <div class="modal modal-lg" @onclick:stopPropagation>
            <div class="modal-header">
                <h2>Imputer - @(acompteAImputer.ClientNom ?? acompteAImputer.FournisseurNom)</h2>
                <button class="btn-close" @onclick="() => showImputation = false">×</button>
            </div>
            <div class="modal-body">
                <div class="acompte-detail-banner">
                    <span>Disponible : <strong class="text-success">@acompteAImputer.MontantDisponible.ToString("N2") F</strong></span>
                    <span>Réf. : <em>@(acompteAImputer.Reference ?? "-")</em></span>
                </div>
                <div class="field-group" style="margin-top:12px">
                    <label class="field-label">Montant à imputer (0 = tout utiliser)</label>
                    <input class="field-input" type="number" step="0.01" @bind="imputationMontant" />
                </div>
                <div style="margin-top:14px">
                    <label class="field-label">Facture à solder</label>
                    @if (chargementDocs) { <div class="loading-state"><div class="spinner-lg"></div></div> }
                    else if (!documentsImputables.Any())
                    {
                        <div class="empty-state">Aucune facture non soldée pour ce tiers.</div>
                    }
                    else
                    {
                        <div class="table-container" style="max-height:240px;overflow-y:auto">
                            <table class="data-table" style="font-size:12px">
                                <thead><tr>
                                    <th>N° document</th><th>Date</th>
                                    <th class="text-right">TTC</th><th class="text-right">Solde</th><th></th>
                                </tr></thead>
                                <tbody>
                                @foreach (var d in documentsImputables)
                                {
                                    <tr>
                                        <td><code>@d.Numero</code></td>
                                        <td class="text-muted small">@d.DateDocument.ToString("dd/MM/yyyy")</td>
                                        <td class="text-right mono">@d.MontantTTC.ToString("N2") F</td>
                                        <td class="text-right mono text-warn">@d.Solde.ToString("N2") F</td>
                                        <td>
                                            <button class="btn-primary" style="font-size:11px;padding:4px 10px"
                                                    @onclick="() => ConfirmerImputation(d)" disabled="@saving">
                                                Imputer
                                            </button>
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="() => showImputation = false">Fermer</button>
            </div>
        </div>
    </div>
}

@if (showConsultReglement && reglementSelectionne != null)
{
    <div class="modal-overlay" @onclick="FermerConsultationReglement">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <h2>Consultation règlement</h2>
                <button class="btn-close" @onclick="FermerConsultationReglement">×</button>
            </div>
            <div class="modal-body">
                <div class="form-grid">
                    <div class="field-group"><label class="field-label">Document</label><div class="field-input">@(reglementSelectionne.NumeroDoc ?? "-")</div></div>
                    <div class="field-group"><label class="field-label">Tiers</label><div class="field-input">@(reglementSelectionne.TiersNom ?? "-")</div></div>
                    <div class="field-group"><label class="field-label">Date</label><div class="field-input">@reglementSelectionne.DateReglement.ToString("dd/MM/yyyy")</div></div>
                    <div class="field-group"><label class="field-label">Mode</label><div class="field-input">@reglementSelectionne.ModeLibelle</div></div>
                    <div class="field-group"><label class="field-label">Montant</label><div class="field-input">@reglementSelectionne.Montant.ToString("N2") F</div></div>
                    <div class="field-group"><label class="field-label">Référence</label><div class="field-input">@(string.IsNullOrWhiteSpace(reglementSelectionne.Reference) ? "-" : reglementSelectionne.Reference)</div></div>
                </div>
            </div>
            <div class="modal-footer">
