                            <option value="2">Commande fournisseur</option>
                            <option value="3">Bon de réception</option>
                            <option value="4">Facture fournisseur</option>
                            <option value="5">Avoir fournisseur</option>
                        </select>
                    </div>
                    <div class="field-group tiers-search-group">
                        <label class="field-label">Fournisseur *</label>
                        <div class="tiers-search-wrap">
                            <input class="field-input tiers-search-input"
                                   placeholder="Rechercher un fournisseur…"
                                   value="@rechercheQuatreDoc"
                                   @onfocus="() => showDropdownFour = true"
                                   @oninput="FiltrerFournisseurs" />
                            @if (!string.IsNullOrEmpty(fAFournisseurNom))
                            {
                                <span class="tiers-selected-badge">
                                    ✓ @fAFournisseurNom
                                    <button class="tiers-clear-btn" @onclick="DeselectFournisseur">✕</button>
                                </span>
                            }
                            @if (showDropdownFour && fournisseursFiltresDoc.Any())
                            {
                                <div class="tiers-dropdown">
                                    @foreach (var f in fournisseursFiltresDoc.Take(8))
                                    {
                                        <button class="tiers-dropdown-item" @onclick="() => SelectFournisseur(f)">
                                            <span class="tiers-dd-rs">@f.RaisonSociale</span>
                                            <span class="tiers-dd-sub">@f.Code</span>
                                        </button>
                                    }
