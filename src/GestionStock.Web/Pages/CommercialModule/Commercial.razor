@page "/commercial"
@attribute [Authorize]
@inject IApiService Api

<PageTitle>Commercial – GestionStock</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Gestion Commerciale</h1>
        <p class="page-date">Ventes · Achats · Clients · Règlements</p>
    </div>
    <div class="header-actions">
        @if (onglet == "ventes")
        {
            <button class="btn-primary" @onclick="OuvrirCreationVente">+ Nouveau document</button>
        }
        else if (onglet == "achats")
        {
            <button class="btn-primary" @onclick="OuvrirCreationAchat">+ Nouveau document</button>
        }
        else if (onglet == "clients")
        {
            <button class="btn-primary" @onclick="OuvrirCreationClient">+ Nouveau client</button>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(message)) { <div class="@msgCls">@message</div> }

@* ── Onglets principaux ──────────────────────────────────────────────────── *@
<div class="comm-tabs">
    <button class="comm-tab @(onglet=="dashboard"?"comm-tab--active":"")" @onclick='() => SetOnglet("dashboard")'>📊 Tableau de bord</button>
    <button class="comm-tab @(onglet=="ventes"?"comm-tab--active":"")" @onclick='() => SetOnglet("ventes")'>📄 Ventes</button>
    <button class="comm-tab @(onglet=="achats"?"comm-tab--active":"")" @onclick='() => SetOnglet("achats")'>🛒 Achats</button>
    <button class="comm-tab @(onglet=="clients"?"comm-tab--active":"")" @onclick='() => SetOnglet("clients")'>👤 Clients</button>
</div>

@* ═══════════════════════════════════════════════════════
   ONGLET DASHBOARD
═══════════════════════════════════════════════════════ *@
@if (onglet == "dashboard")
{
    @if (chargementDash) { <div class="loading-state"><div class="spinner-lg"></div></div> }
    else if (dash != null)
    {
        <div class="stat-cards-grid" style="margin-top:16px">
            <div class="stat-card stat-card--blue">
                <div class="stat-icon">👤</div>
                <div class="stat-value">@dash.NbClients</div>
                <div class="stat-label">Clients actifs</div>
            </div>
            <div class="stat-card stat-card--amber">
                <div class="stat-icon">📋</div>
                <div class="stat-value">@dash.DevisOuverts</div>
                <div class="stat-label">Devis ouverts</div>
            </div>
            <div class="stat-card stat-card--teal">
                <div class="stat-icon">📦</div>
                <div class="stat-value">@dash.CommandesEnCours</div>
                <div class="stat-label">Commandes en cours</div>
            </div>
            <div class="stat-card stat-card--red">
                <div class="stat-icon">🧾</div>
                <div class="stat-value">@dash.FacturesNonReglees</div>
                <div class="stat-label">Factures à encaisser</div>
            </div>
            <div class="stat-card stat-card--green">
                <div class="stat-icon">💶</div>
                <div class="stat-value">@dash.CaMois.ToString("N0") €</div>
                <div class="stat-label">CA du mois</div>
            </div>
            <div class="stat-card @(dash.EncoursClient > 0 ? "stat-card--amber" : "stat-card--gray")">
                <div class="stat-icon">⏳</div>
                <div class="stat-value">@dash.EncoursClient.ToString("N0") €</div>
                <div class="stat-label">Encours clients</div>
            </div>
            <div class="stat-card stat-card--blue">
                <div class="stat-icon">🛒</div>
                <div class="stat-value">@dash.CommandesFourn</div>
                <div class="stat-label">Cdes fournisseurs</div>
            </div>
        </div>
        <div style="margin-top:24px">
            <h3 class="section-title">Flux de transformation</h3>
            <div class="flux-diagram">
                <div class="flux-group">
                    <div class="flux-title">📄 VENTES</div>
                    <div class="flux-steps">
                        <span class="flux-step flux-step--1">Devis</span>
                        <span class="flux-arrow">→</span>
                        <span class="flux-step flux-step--2">Commande</span>
                        <span class="flux-arrow">→</span>
                        <span class="flux-step flux-step--3">Bon de livraison</span>
                        <span class="flux-arrow">→</span>
                        <span class="flux-step flux-step--4">Facture</span>
                        <span class="flux-arrow">→</span>
                        <span class="flux-step flux-step--5">Avoir</span>
                    </div>
                </div>
                <div class="flux-group" style="margin-top:12px">
                    <div class="flux-title">🛒 ACHATS</div>
                    <div class="flux-steps">
                        <span class="flux-step flux-step--1">Demande</span>
                        <span class="flux-arrow">→</span>
                        <span class="flux-step flux-step--2">Commande</span>
                        <span class="flux-arrow">→</span>
                        <span class="flux-step flux-step--3">Réception</span>
                        <span class="flux-arrow">→</span>
                        <span class="flux-step flux-step--4">Facture</span>
                        <span class="flux-arrow">→</span>
                        <span class="flux-step flux-step--5">Avoir</span>
                    </div>
                </div>
            </div>
        </div>
    }
}

@* ═══════════════════════════════════════════════════════
   ONGLET VENTES
═══════════════════════════════════════════════════════ *@
@if (onglet == "ventes")
{
    <div class="toolbar" style="margin-top:12px">
        <div class="toolbar-filters" style="flex-wrap:wrap;gap:6px">
            @foreach (var tf in TypesVente)
            {
                <button class="btn-secondary @(filtreTypeVente==tf.Id?"btn-active":"")"
                        @onclick="() => SetFiltreVente(tf.Id)">@tf.Libelle</button>
            }
        </div>
        <div class="search-box">
            <span class="search-icon">🔍</span>
            <input class="search-input" type="text" placeholder="N°, client…"
                   @bind="rechercheVente" @bind:event="oninput" />
        </div>
    </div>

    @if (chargementVentes) { <div class="loading-state"><div class="spinner-lg"></div></div> }
    else
    {
        <div class="table-container">
            <table class="data-table">
                <thead><tr>
                    <th>N° Document</th><th>Type</th><th>Client</th><th>Date</th>
                    <th class="text-right">HT</th><th class="text-right">TTC</th>
                    <th class="text-right">Solde</th><th>Statut</th><th>Actions</th>
                </tr></thead>
                <tbody>
                @foreach (var d in VentesFiltrees)
                {
                    <tr class="@(d.EstVerrouille?"row-locked":"")">
                        <td><code class="mono">@d.Numero</code></td>
                        <td><span class="badge @GetBadgeVente(d.TypeDocument)">@d.TypeLibelle</span></td>
                        <td class="cell-main">@d.ClientNom</td>
                        <td class="small text-muted">@d.DateDocument.ToString("dd/MM/yyyy")</td>
                        <td class="text-right mono small">@d.MontantHT.ToString("N2") €</td>
                        <td class="text-right mono">@d.MontantTTC.ToString("N2") €</td>
                        <td class="text-right mono @(d.Solde>0&&d.TypeDocument==4?"text-warn":"")">@d.Solde.ToString("N2") €</td>
                        <td>
                            <span class="badge @GetStatutBadgeVente(d.Statut)">@d.StatutLibelle</span>
                            @if (d.EstVerrouille) { <span style="margin-left:4px" title="Réglé">🔒</span> }
                        </td>
                        <td class="actions-cell">
                            @if (d.Statut == 1 && !d.EstVerrouille)
                            { <button class="btn-icon btn-icon-success" title="Valider" @onclick="() => ValiderVente(d)">✓</button> }
                            @if (d.TypeDocument < 5 && !d.EstVerrouille && d.Statut >= 2 && d.Statut <= 7)
                            { <button class="btn-icon" title="Transformer →" @onclick="() => OuvrirTransfo(d)">→</button> }
                            @if (d.TypeDocument == 4 && d.Solde > 0 && !d.EstVerrouille)
                            { <button class="btn-icon btn-icon-success" title="Encaisser" @onclick="() => OuvrirReglement(d)">💶</button> }
                            @if (!d.EstVerrouille && d.Statut < 9)
                            { <button class="btn-icon btn-icon-danger" title="Annuler" @onclick="() => AnnulerVente(d)">✕</button> }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        @if (!ventes.Any()) { <div class="empty-state">Aucun document de vente. Cliquez "+ Nouveau document".</div> }
        else if (!VentesFiltrees.Any()) { <div class="empty-state">Aucun document pour ce filtre.</div> }
    }
}

@* ═══════════════════════════════════════════════════════
   ONGLET ACHATS
═══════════════════════════════════════════════════════ *@
@if (onglet == "achats")
{
    <div class="toolbar" style="margin-top:12px">
        <div class="toolbar-filters" style="flex-wrap:wrap;gap:6px">
            @foreach (var tf in TypesAchat)
            {
                <button class="btn-secondary @(filtreTypeAchat==tf.Id?"btn-active":"")"
                        @onclick="() => SetFiltreAchat(tf.Id)">@tf.Libelle</button>
            }
        </div>
    </div>

    @if (chargementAchats) { <div class="loading-state"><div class="spinner-lg"></div></div> }
    else
    {
        <div class="table-container">
            <table class="data-table">
                <thead><tr>
                    <th>N° Document</th><th>Type</th><th>Fournisseur</th><th>Date</th>
                    <th>Livraison prévue</th><th class="text-right">TTC</th>
                    <th class="text-right">Solde</th><th>Statut</th><th>Actions</th>
                </tr></thead>
                <tbody>
                @foreach (var d in achats)
                {
                    <tr class="@(d.EstVerrouille?"row-locked":"")">
                        <td><code class="mono">@d.Numero</code></td>
                        <td><span class="badge @GetBadgeAchat(d.TypeDocument)">@d.TypeLibelle</span></td>
                        <td class="cell-main">@d.FournisseurNom</td>
                        <td class="small text-muted">@d.DateDocument.ToString("dd/MM/yyyy")</td>
                        <td class="small text-muted">@(d.DateLivraisonPrevue?.ToString("dd/MM/yyyy") ?? "—")</td>
                        <td class="text-right mono">@d.MontantTTC.ToString("N2") €</td>
                        <td class="text-right mono @(d.Solde>0&&d.TypeDocument==4?"text-warn":"")">@d.Solde.ToString("N2") €</td>
                        <td><span class="badge @GetStatutBadgeAchat(d.Statut)">@d.StatutLibelle</span>
                            @if (d.EstVerrouille) { <span title="Réglé">🔒</span> }</td>
                        <td class="actions-cell">
                            @if (d.TypeDocument < 4 && !d.EstVerrouille)
                            { <button class="btn-icon" title="Transformer →" @onclick="() => OuvrirTransfoAchat(d)">→</button> }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        @if (!achats.Any()) { <div class="empty-state">Aucun document d'achat. Cliquez "+ Nouveau document".</div> }
    }
}

@* ═══════════════════════════════════════════════════════
   ONGLET CLIENTS
═══════════════════════════════════════════════════════ *@
@if (onglet == "clients")
{
    <div class="toolbar" style="margin-top:12px">
        <div class="search-box">
            <span class="search-icon">🔍</span>
            <input class="search-input" type="text" placeholder="Nom, email…"
                   @bind="rechercheClient" @bind:event="oninput" />
        </div>
        <div class="toolbar-right">
            <span class="record-count">@ClientsFiltres.Count() client(s)</span>
        </div>
    </div>
    @if (chargementClients) { <div class="loading-state"><div class="spinner-lg"></div></div> }
    else
    {
        <div class="table-container">
            <table class="data-table">
                <thead><tr>
                    <th>Code</th><th>Client</th><th>Type</th><th>Email</th>
                    <th>Ville</th><th class="text-right">Remise</th>
                    <th class="text-right">Délai</th><th class="text-right">Encours</th><th></th>
                </tr></thead>
                <tbody>
                @foreach (var c in ClientsFiltres)
                {
                    <tr class="@(!c.EstActif?"row-inactive":"")">
                        <td><code>@c.Code</code></td>
                        <td class="cell-main">@c.RaisonSociale</td>
                        <td><span class="badge @(c.TypeClient==1?"badge-gray":"badge-blue")">@(c.TypeClient==1?"Particulier":"Pro")</span></td>
                        <td class="small text-muted">@c.Email</td>
                        <td class="small text-muted">@c.Ville</td>
                        <td class="text-right mono">@c.TauxRemise.ToString("N1") %</td>
                        <td class="text-right mono">@c.DelaiPaiementJours j</td>
                        <td class="text-right mono @(c.Encours>0?"text-warn":"")">@c.Encours.ToString("N2") €</td>
                        <td class="actions-cell">
                            <button class="btn-icon" title="Modifier" @onclick="() => OuvrirEditionClient(c)">✎</button>
                            <button class="btn-icon" title="Documents" @onclick="() => VoirDocumentsClient(c)">📄</button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        @if (!clients.Any()) { <div class="empty-state">Aucun client.</div> }
    }
}

@* ═══════════════════════════════════════════════════════
   MODALS VENTES
═══════════════════════════════════════════════════════ *@

@* Création document vente *@
@if (showCreationVente)
{
    <div class="modal-overlay" @onclick="() => showCreationVente = false">
        <div class="modal modal-xl" @onclick:stopPropagation>
            <div class="modal-header">
                <h2>+ Nouveau document de vente</h2>
                <button class="btn-close" @onclick="() => showCreationVente = false">✕</button>
            </div>
            <div class="modal-body">
                <div class="form-grid">
                    <div class="field-group">
                        <label class="field-label">Type *</label>
                        <select class="field-input" @bind="fVType">
                            <option value="1">Devis</option>
                            <option value="2">Commande client</option>
                            <option value="3">Bon de livraison</option>
                            <option value="4">Facture</option>
                            <option value="5">Avoir client</option>
                        </select>
                    </div>
                    <div class="field-group tiers-search-group">
                        <label class="field-label">Client *</label>
                        <div class="tiers-search-wrap">
                            <input class="field-input tiers-search-input"
                                   placeholder="Rechercher un client…"
                                   value="@rechercheClientDoc"
                                   @onfocus="() => showDropdownClient = true"
                                   @oninput="FiltrerClients" />
                            @if (!string.IsNullOrEmpty(fVClientNom))
                            {
                                <span class="tiers-selected-badge">
                                    ✓ @fVClientNom
                                    <button class="tiers-clear-btn" @onclick="DeselectClient">✕</button>
                                </span>
                            }
                            @if (showDropdownClient && clientsFiltresDoc.Any())
                            {
                                <div class="tiers-dropdown">
                                    @foreach (var cl in clientsFiltresDoc.Take(8))
                                    {
                                        <button class="tiers-dropdown-item" @onclick="() => SelectClient(cl)">
                                            <span class="tiers-dd-rs">@cl.RaisonSociale</span>
                                            <span class="tiers-dd-sub">@cl.Code @(cl.Ville != null ? "· " + cl.Ville : "")</span>
                                        </button>
                                    }
                                    <button class="tiers-dropdown-create" @onclick="OuvrirCreationClientRapide">
                                        + Créer "@rechercheClientDoc"
                                    </button>
                                </div>
                            }
                            @if (showDropdownClient && !clientsFiltresDoc.Any() && !string.IsNullOrWhiteSpace(rechercheClientDoc))
                            {
                                <div class="tiers-dropdown">
                                    <div class="tiers-dropdown-empty">Aucun client trouvé</div>
                                    <button class="tiers-dropdown-create" @onclick="OuvrirCreationClientRapide">
                                        + Créer "@rechercheClientDoc"
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="field-group">
                        <label class="field-label">Date</label>
                        <input class="field-input" type="date" @bind="fVDate" />
                    </div>
                    <div class="field-group">
                        <label class="field-label">Échéance</label>
                        <input class="field-input" type="date" @bind="fVEcheance" />
                    </div>
                    <div class="field-group">
                        <label class="field-label">Frais livraison (€)</label>
                        <input class="field-input" type="number" step="0.01" min="0" @bind="fVFraisLiv" />
                    </div>
                    <div class="field-group">
                        <label class="field-label">Acompte (€)</label>
                        <input class="field-input" type="number" step="0.01" min="0" @bind="fVAcompte" />
                    </div>
                    <div class="field-group col-span-2">
                        <label class="field-label">Notes client</label>
                        <textarea class="field-input" rows="2" @bind="fVNotes"></textarea>
                    </div>
                </div>

                @* ── Lignes ── *@
                <div style="margin-top:16px">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
                        <label class="field-label" style="margin:0">Lignes articles</label>
                        <button class="btn-secondary" style="font-size:12px" @onclick="AjouterLigneVente">+ Ajouter</button>
                    </div>
                    @if (fVLignes.Any())
                    {
                        <div class="table-container" style="max-height:260px;overflow-y:auto">
                            <table class="data-table" style="font-size:12px">
                                <thead><tr>
                                    <th>Article</th><th>Désignation</th>
                                    <th class="text-right">Qté</th><th class="text-right">PU HT</th>
                                    <th class="text-right">Rem.%</th><th class="text-right">TVA%</th>
                                    <th class="text-right">Montant TTC</th><th></th>
                                </tr></thead>
                                <tbody>
                                @for (var i = 0; i < fVLignes.Count; i++)
                                {
                                    var idx = i;
                                    var l = fVLignes[idx];
                                    <tr>
                                        <td>
                                            <select class="field-input" style="width:130px"
                                                    @bind="l.ArticleId" @bind:after="() => OnArticleSelectVente(idx)">
                                                <option value="@Guid.Empty">—</option>
                                                @foreach (var a in articles)
                                                { <option value="@a.Id">[@a.Code] @a.Designation</option> }
                                            </select>
                                        </td>
                                        <td><input class="field-input" @bind="l.Designation" style="width:140px" /></td>
                                        <td><input class="field-input text-right" type="number" step="0.001" @bind="l.Quantite" style="width:65px" /></td>
                                        <td><input class="field-input text-right" type="number" step="0.01" @bind="l.PrixUnitaireHT" style="width:80px" /></td>
                                        <td><input class="field-input text-right" type="number" step="0.1" @bind="l.TauxRemise" style="width:55px" /></td>
                                        <td><input class="field-input text-right" type="number" step="0.1" @bind="l.TauxTVA" style="width:55px" /></td>
                                        <td class="text-right mono">@((l.Quantite * l.PrixUnitaireHT * (1m - l.TauxRemise / 100m) * (1m + l.TauxTVA / 100m)).ToString("N2")) €</td>
                                        <td><button class="btn-icon btn-icon-danger" @onclick="() => SupprimerLigneVente(idx)">✕</button></td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                        <div class="doc-totaux">
                            <span>HT : <strong>@TotalHTVente.ToString("N2") €</strong></span>
                            <span>TVA : <strong>@TotalTVAVente.ToString("N2") €</strong></span>
                            @if (fVFraisLiv > 0) { <span>Frais liv. : <strong>@fVFraisLiv.ToString("N2") €</strong></span> }
                            @if (fVAcompte > 0) { <span>Acompte : <strong>-@fVAcompte.ToString("N2") €</strong></span> }
                            <span class="total-ttc">Total TTC : <strong>@TotalTTCVente.ToString("N2") €</strong></span>
                        </div>
                    }
                    else { <div class="empty-state" style="padding:10px">Ajoutez des articles.</div> }
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="() => showCreationVente = false">Annuler</button>
                <button class="btn-primary" @onclick="CreerDocumentVente" disabled="@saving">
                    @(saving ? "Création…" : "Créer le document")
                </button>
            </div>
        </div>
    </div>
}

@* Transformation vente *@
@if (showTransfoVente && docVenteSelectionne != null)
{
    <div class="modal-overlay" @onclick="() => showTransfoVente = false">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <h2>→ Transformer @docVenteSelectionne.Numero</h2>
                <button class="btn-close" @onclick="() => showTransfoVente = false">✕</button>
            </div>
            <div class="modal-body">
                <div class="transfo-info">
                    <span class="badge @GetBadgeVente(docVenteSelectionne.TypeDocument)">@docVenteSelectionne.TypeLibelle</span>
                    <span class="flux-arrow">→</span>
                    <span class="text-muted small">@docVenteSelectionne.ClientNom — @docVenteSelectionne.MontantTTC.ToString("N2") €</span>
                </div>
                <div class="transfo-choices" style="margin-top:14px">
                    @foreach (var td in GetTransfoVente(docVenteSelectionne.TypeDocument))
                    {
                        <button class="transfo-btn" @onclick="() => TransformerVente(td.Id)">
                            <span class="badge @GetBadgeVente(td.Id)">@td.Libelle</span>
                        </button>
                    }
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="() => showTransfoVente = false">Annuler</button>
            </div>
        </div>
    </div>
}

@* Règlement *@
@if (showReglement && docVenteSelectionne != null)
{
    <div class="modal-overlay" @onclick="() => showReglement = false">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <h2>💶 Encaisser — @docVenteSelectionne.Numero</h2>
                <button class="btn-close" @onclick="() => showReglement = false">✕</button>
            </div>
            <div class="modal-body">
                <div class="form-grid">
                    <div class="field-group col-span-2">
                        <label class="field-label">Solde restant</label>
                        <div class="field-input" style="background:rgba(0,0,0,.03);font-weight:700;color:var(--col-amber)">
                            @docVenteSelectionne.Solde.ToString("N2") €
                        </div>
                    </div>
                    <div class="field-group">
                        <label class="field-label">Montant *</label>
                        <input class="field-input" type="number" step="0.01" @bind="rMontant" />
                    </div>
                    <div class="field-group">
                        <label class="field-label">Mode de paiement</label>
                        <select class="field-input" @bind="rMode">
                            <option value="1">Espèces</option>
                            <option value="2">Chèque</option>
                            <option value="3">Virement</option>
                            <option value="4">Carte bancaire</option>
                            <option value="5">Prélèvement</option>
                            <option value="6">Traite</option>
                            <option value="7">Autre</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label class="field-label">Date règlement</label>
                        <input class="field-input" type="date" @bind="rDate" />
                    </div>
                    <div class="field-group">
                        <label class="field-label">Référence</label>
