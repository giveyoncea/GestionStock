    private async Task CreerFournisseurRapide()
    {
        if (string.IsNullOrWhiteSpace(qfRs)) { message="Nom obligatoire."; msgCls="alert-error"; return; }
        saving=true;
        // Génère un code auto basé sur le nom
        var qfCode = "F" + qfRs.Replace(" ","").ToUpperInvariant()[..Math.Min(4, qfRs.Replace(" ","").Length)];
        var r = await Api.CreerFournisseurAsync(new CreerFournisseurDto(
            Code: qfCode, RaisonSociale: qfRs, Siret: "",
            Email: qfEmail, Telephone: qfTel, Adresse: "",
            Ville: qfVille, CodePostal: "", Pays: "France",
            DelaiLivraisonJours: qfDelai
        ));
        saving=false;
        if (r?.Succes == true)
        {
            var paged = await Api.GetFournisseursAsync(1, 500);
            fournisseurs = paged?.Items.ToList() ?? new();
            var nouveau = fournisseurs.FirstOrDefault(f =>
                f.RaisonSociale.Equals(qfRs, StringComparison.OrdinalIgnoreCase));
            if (nouveau != null) SelectFournisseur(nouveau);
            showCreationFournisseurRapide = false;
            message = $"Fournisseur \"{qfRs}\" créé et sélectionné.";
            msgCls = "alert-success";
        }
        else { message = r?.Message ?? "Erreur."; msgCls = "alert-error"; }
    }

