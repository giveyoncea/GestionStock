@code {
    private string onglet = "dashboard";
    private string? message; private string msgCls = "alert-success";
    private bool saving = false;

    // Data
    private CommercialDashboardDto? dash;
    private List<DocumentVenteDto> ventes = new();
    private List<DocumentAchatDto> achats = new();
    private List<ClientDto> clients = new();
    private List<FournisseurDto> fournisseurs = new();
    private List<ArticleDto> articles = new();

    // Loading
    private bool chargementDash=true, chargementVentes=false, chargementAchats=false, chargementClients=false;

    // Filtres
    private int filtreTypeVente = 0;
    private int filtreTypeAchat = 0;
    private string rechercheVente = "", rechercheClient = "";
    private IEnumerable<DocumentVenteDto> VentesFiltrees => ventes.Where(d =>
        string.IsNullOrWhiteSpace(rechercheVente) ||
        d.Numero.Contains(rechercheVente, StringComparison.OrdinalIgnoreCase) ||
        d.ClientNom.Contains(rechercheVente, StringComparison.OrdinalIgnoreCase));
    private IEnumerable<ClientDto> ClientsFiltres => string.IsNullOrWhiteSpace(rechercheClient) ? clients
        : clients.Where(c => c.RaisonSociale.Contains(rechercheClient, StringComparison.OrdinalIgnoreCase)
            || (c.Email??string.Empty).Contains(rechercheClient, StringComparison.OrdinalIgnoreCase));

    private record TypeDocItem(int Id, string Libelle);
    private static readonly TypeDocItem[] TypesVente = {
        new(0,"Tous"), new(1,"Devis"), new(2,"Commandes"), new(3,"BL"), new(4,"Factures"), new(5,"Avoirs")
    };
    private static readonly TypeDocItem[] TypesAchat = {
        new(0,"Tous"), new(1,"Demandes"), new(2,"Cdes fourn."), new(3,"Réceptions"), new(4,"Factures fourn."), new(5,"Avoirs fourn.")
    };

    // Modals
    private bool showCreationVente=false, showTransfoVente=false, showReglement=false;
    private bool showCreationAchat=false, showTransfoAchat=false;
    private bool showModalClient=false;
    private DocumentVenteDto? docVenteSelectionne;
    private DocumentAchatDto? docAchatSelectionne;
    private ClientDto? clientEdite;

    // Tiers search state
    private string rechercheClientDoc = "";
    private string rechercheQuatreDoc = "";
    private string fVClientNom = "";
    private string fAFournisseurNom = "";
    private bool showDropdownClient = false;
    private bool showDropdownFour = false;
    private List<ClientDto> clientsFiltresDoc = new();
    private List<FournisseurDto> fournisseursFiltresDoc = new();

    // Quick create client
    private bool showCreationClientRapide = false;
    private string qcRs="", qcEmail="", qcTel="", qcVille="";
    private int qcType=2, qcDelai=30; private decimal qcRemise=0;

    // Quick create fournisseur
    private bool showCreationFournisseurRapide = false;
    private string qfRs="", qfEmail="", qfTel="", qfVille="";
    private int qfDelai=7;

    // Form vente
    private int fVType=1; private string fVClientId="";
    private DateTime fVDate=DateTime.Today; private DateTime? fVEcheance;
    private decimal fVFraisLiv=0, fVAcompte=0; private string fVNotes="";
    private List<LigneDocRequest> fVLignes = new();
    private decimal TotalHTVente => fVLignes.Sum(l => l.Quantite * l.PrixUnitaireHT * (1m - l.TauxRemise/100m));
    private decimal TotalTVAVente => fVLignes.Sum(l => l.Quantite * l.PrixUnitaireHT * (1m - l.TauxRemise/100m) * l.TauxTVA/100m);
    private decimal TotalTTCVente => TotalHTVente + TotalTVAVente + fVFraisLiv - fVAcompte;

    // Form achat
    private int fAType=1; private string fAFournisseurId="";
    private DateTime fADate=DateTime.Today; private DateTime? fADlivPrevue;
    private decimal fAFraisLiv=0; private string fANotes="";
    private List<LigneDocRequest> fALignes = new();
    private decimal TotalHTAchat => fALignes.Sum(l => l.Quantite * l.PrixUnitaireHT * (1m - l.TauxRemise/100m));
    private decimal TotalTVAAchat => fALignes.Sum(l => l.Quantite * l.PrixUnitaireHT * (1m - l.TauxRemise/100m) * l.TauxTVA/100m);
    private decimal TotalTTCAchat => TotalHTAchat + TotalTVAAchat + fAFraisLiv;

    // Form client
    private string fCRs="", fCEmail="", fCTel="", fCVille="";
    private int fCType=2, fCDelai=30; private decimal fCRemise=0, fCPlafond=0;

    // Règlement
    private decimal rMontant=0; private int rMode=1;
    private DateTime rDate=DateTime.Today; private string rRef="";

    protected override async Task OnInitializedAsync()
    {
        // Charge le dashboard + données de base en parallèle
        await Task.WhenAll(
            Task.Run(async () => dash = await Api.GetCommercialDashboardAsync()),
            Task.Run(async () => clients = await Api.GetClientsAsync() ?? new()),
            Task.Run(async () => {
                var r = await Api.GetFournisseursAsync(1, 500);
                fournisseurs = r?.Items.ToList() ?? new();
            }),
            Task.Run(async () => {
                var r = await Api.GetArticlesAsync(1, 500, null, null);
                articles = r?.Items.ToList() ?? new();
            })
        );
        chargementDash = false;
    }

    private async Task SetOnglet(string tab)
    {
        onglet = tab;
        message = null;
        if (tab == "ventes" && !ventes.Any()) await ChargerVentes();
        else if (tab == "achats" && !achats.Any()) await ChargerAchats();
        else if (tab == "clients" && !clients.Any()) { chargementClients=true; clients=await Api.GetClientsAsync()??new(); chargementClients=false; }
    }

    private async Task ChargerVentes()
    {
        chargementVentes=true;
        ventes = await Api.GetVentesAsync(filtreTypeVente==0?null:filtreTypeVente) ?? new();
        chargementVentes=false;
    }

    private async Task ChargerAchats()
    {
        chargementAchats=true;
        achats = await Api.GetAchatsCommAsync(filtreTypeAchat==0?null:filtreTypeAchat) ?? new();
        chargementAchats=false;
    }

    private async Task SetFiltreVente(int type)
    { filtreTypeVente=type; await ChargerVentes(); }

    private async Task SetFiltreAchat(int type)
    { filtreTypeAchat=type; await ChargerAchats(); }

    // ── Ventes CRUD ──────────────────────────────────────────────────────────
    // ── Tiers search methods ──────────────────────────────────────────────────
    private void FiltrerClients(Microsoft.AspNetCore.Components.ChangeEventArgs e)
    {
        rechercheClientDoc = e.Value?.ToString() ?? "";
        showDropdownClient = true;
        clientsFiltresDoc = string.IsNullOrWhiteSpace(rechercheClientDoc)
            ? clients.Take(8).ToList()
            : clients.Where(c => c.RaisonSociale.Contains(rechercheClientDoc, StringComparison.OrdinalIgnoreCase)
                               || c.Code.Contains(rechercheClientDoc, StringComparison.OrdinalIgnoreCase)
                               || (c.Email??string.Empty).Contains(rechercheClientDoc, StringComparison.OrdinalIgnoreCase))
                     .Take(8).ToList();
    }

    private void SelectClient(ClientDto cl)
    {
        fVClientId = cl.Id.ToString();
        fVClientNom = cl.RaisonSociale;
        rechercheClientDoc = "";
        showDropdownClient = false;
        clientsFiltresDoc = new();
    }

    private void DeselectClient()
    { fVClientId=""; fVClientNom=""; rechercheClientDoc=""; showDropdownClient=false; }

    private void FiltrerFournisseurs(Microsoft.AspNetCore.Components.ChangeEventArgs e)
    {
        rechercheQuatreDoc = e.Value?.ToString() ?? "";
        showDropdownFour = true;
        fournisseursFiltresDoc = string.IsNullOrWhiteSpace(rechercheQuatreDoc)
            ? fournisseurs.Take(8).ToList()
            : fournisseurs.Where(f => f.RaisonSociale.Contains(rechercheQuatreDoc, StringComparison.OrdinalIgnoreCase)
                                  || f.Code.Contains(rechercheQuatreDoc, StringComparison.OrdinalIgnoreCase))
                         .Take(8).ToList();
    }

    private void SelectFournisseur(FournisseurDto f)
    {
        fAFournisseurId = f.Id.ToString();
        fAFournisseurNom = f.RaisonSociale;
        rechercheQuatreDoc = "";
        showDropdownFour = false;
        fournisseursFiltresDoc = new();
    }

    private void DeselectFournisseur()
    { fAFournisseurId=""; fAFournisseurNom=""; rechercheQuatreDoc=""; showDropdownFour=false; }

    // ── Quick create ───────────────────────────────────────────────────────────
    private void OuvrirCreationClientRapide()
    {
        qcRs=rechercheClientDoc; qcEmail=qcTel=qcVille=""; qcType=2; qcDelai=30; qcRemise=0;
        showDropdownClient=false; showCreationClientRapide=true;
    }

    private async Task CreerClientRapide()
    {
        if (string.IsNullOrWhiteSpace(qcRs)) { message="Nom obligatoire."; msgCls="alert-error"; return; }
        saving=true;
        var r = await Api.CreerClientAsync(new ClientRequest {
            RaisonSociale=qcRs, TypeClient=qcType, Email=qcEmail,
            Telephone=qcTel, Ville=qcVille, DelaiPaiementJours=qcDelai, TauxRemise=qcRemise
        });
        saving=false;
        if (r?.Succes == true)
        {
            // Recharger les clients et sélectionner automatiquement le nouveau
            clients = await Api.GetClientsAsync() ?? new();
            var nouveau = clients.FirstOrDefault(cl =>
                cl.RaisonSociale.Equals(qcRs, StringComparison.OrdinalIgnoreCase));
            if (nouveau != null) SelectClient(nouveau);
            showCreationClientRapide = false;
            message = $"Client \"{qcRs}\" créé et sélectionné.";
            msgCls = "alert-success";
        }
        else { message = r?.Message ?? "Erreur."; msgCls = "alert-error"; }
    }

