    private async Task SauvegarderClient()
    {
        if (string.IsNullOrWhiteSpace(fCRs)) { message="Raison sociale obligatoire."; msgCls="alert-error"; return; }
        saving=true;
        var dto = new ClientRequest { RaisonSociale=fCRs, TypeClient=fCType, Email=fCEmail,
            Telephone=fCTel, Ville=fCVille, DelaiPaiementJours=fCDelai,
            TauxRemise=fCRemise, PlafondCredit=fCPlafond };
        ResultDto? r;
        if (clientEdite==null) r = await Api.CreerClientAsync(dto);
        else r = await Api.ModifierClientAsync(clientEdite.Id, dto);
        saving=false; msgCls=r?.Succes==true?"alert-success":"alert-error"; message=r?.Message;
        if (r?.Succes==true)
        {
            showModalClient=false;
            chargementClients=true;
            clients=await Api.GetClientsAsync()??new();
            chargementClients=false;
        }
    }

