   ONGLET CLIENTS
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• *@
@if (onglet == "clients")
{
    <div class="toolbar" style="margin-top:12px">
        <div class="search-box">
            <span class="search-icon">🔍</span>
            <input class="search-input" type="text" placeholder="Nom, email..."
                   @bind="rechercheClient" @bind:event="oninput" />
        </div>
        <div class="toolbar-right">
            <span class="record-count">@ClientsFiltres.Count() client(s)</span>
        </div>
    </div>
    @if (chargementClients) { <div class="loading-state"><div class="spinner-lg"></div></div> }
    else
    {
        <div class="table-container">
            <table class="data-table">
                <thead><tr>
                    <th>Code</th><th>Client</th><th>Type</th><th>Email</th>
                    <th>Ville</th><th class="text-right">Remise</th>
                    <th class="text-right">Délai</th><th class="text-right">Encours</th><th>Actions</th>
                </tr></thead>
                <tbody>
                @foreach (var c in ClientsFiltres)
                {
                    <tr class="@(!c.EstActif?"row-inactive":"")">
                        <td><code>@c.Code</code></td>
                        <td class="cell-main">@c.RaisonSociale</td>
                        <td><span class="badge @(c.TypeClient==1?"badge-gray":"badge-blue")">@(c.TypeClient==1?"Particulier":"Pro")</span></td>
                        <td class="small text-muted">@c.Email</td>
                        <td class="small text-muted">@c.Ville</td>
                        <td class="text-right mono">@c.TauxRemise.ToString("N1") %</td>
                        <td class="text-right mono">@c.DelaiPaiementJours j</td>
                        <td class="text-right mono @(c.Encours>0?"text-warn":"")">@c.Encours.ToString("N2") F</td>
                        <td class="actions-cell">
                            <details class="row-actions-menu">
                                <summary class="btn-row-action btn-row-action--soft" type="button">Actions</summary>
                                <div class="row-actions-menu-list">
                                    <button type="button" class="btn-row-action btn-row-action--primary" @onclick="() => OuvrirEditionClient(c)">Modifier</button>
                                    <button type="button" class="btn-row-action btn-row-action--print" @onclick="() => VoirDocumentsClient(c)">Documents</button>
                                </div>
                            </details>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        @if (!clients.Any()) { <div class="empty-state">Aucun client.</div> }
    }
}

@if (onglet == "fournisseurs")
{
    <div class="toolbar" style="margin-top:12px">
        <div class="search-box">
            <span class="search-icon">🔍</span>
            <input class="search-input" type="text" placeholder="Nom, email..."
                   @bind="rechercheFournisseur" @bind:event="oninput" />
        </div>
        <div class="toolbar-right">
            <span class="record-count">@FournisseursFiltres.Count() fournisseur(s)</span>
        </div>
    </div>
    <div class="table-container">
        <table class="data-table">
            <thead><tr>
                <th>Code</th><th>Fournisseur</th><th>Email</th><th>Téléphone</th>
                <th>Ville</th><th class="text-right">Délai</th><th class="text-right">Commandes</th><th>Actions</th>
            </tr></thead>
            <tbody>
            @foreach (var f in FournisseursFiltres)
            {
                <tr>
                    <td><code>@f.Code</code></td>
                    <td class="cell-main">@f.RaisonSociale</td>
                    <td class="small text-muted">@f.Email</td>
                    <td class="small text-muted">@f.Telephone</td>
                    <td class="small text-muted">@f.Ville</td>
                    <td class="text-right mono">@f.DelaiLivraisonJours j</td>
                    <td class="text-right mono">@f.NombreCommandes</td>
                    <td class="actions-cell">
                        <details class="row-actions-menu">
                            <summary class="btn-row-action btn-row-action--soft" type="button">Actions</summary>
                            <div class="row-actions-menu-list">
                                <button type="button" class="btn-row-action btn-row-action--primary" @onclick="() => OuvrirEditionFournisseur(f)">Modifier</button>
                                <button type="button" class="btn-row-action btn-row-action--print" @onclick="() => VoirDocumentsFournisseur(f)">Documents</button>
                            </div>
                        </details>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    @if (!fournisseurs.Any()) { <div class="empty-state">Aucun fournisseur.</div> }
}


