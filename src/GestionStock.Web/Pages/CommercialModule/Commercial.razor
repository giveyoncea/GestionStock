@page "/commercial"
@attribute [Authorize]
@inject IApiService Api
@inject IPrintService Print
@inject ICurrencyService Devise

<PageTitle>Commercial - GestionStock</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Gestion Commerciale</h1>
        <p class="page-subtitle">Ventes · Achats · Clients · Fournisseurs · Règlements</p>
    </div>
    <div class="header-actions">
        @if (onglet == "ventes")
        {
            <button class="btn-primary" @onclick="OuvrirCreationVente">+ Nouveau document</button>
        }
        else if (onglet == "achats")
        {
            <button class="btn-primary" @onclick="OuvrirCreationAchat">+ Nouveau document</button>
        }
        else if (onglet == "clients")
        {
            <button class="btn-primary" @onclick="OuvrirCreationClient">+ Nouveau client</button>
        }
        else if (onglet == "fournisseurs")
        {
            <button class="btn-primary" @onclick="OuvrirCreationFournisseurRapide">+ Nouveau fournisseur</button>
        }
    </div>
</div>

<section class="surface-hero surface-hero--compact">
    <div class="surface-hero-copy">
        <span class="surface-hero-eyebrow">Parcours métier</span>
        <h2>Travaillez par domaine avec des actions claires</h2>
        <p>Chaque écran est recentré sur un objectif simple : suivre, créer, consulter et traiter rapidement les documents ou les tiers concernés.</p>
    </div>
    <div class="surface-hero-pills">
        <span class="surface-pill">Devis et factures</span>
        <span class="surface-pill">Achats fournisseurs</span>
        <span class="surface-pill">Gestion des tiers</span>
    </div>
</section>
<div class="comm-tabs">
    <button class="comm-tab @(onglet=="dashboard"?"comm-tab--active":"")" @onclick='() => SetOnglet("dashboard")'>Tableau de bord</button>
    <button class="comm-tab @(onglet=="ventes"?"comm-tab--active":"")" @onclick='() => SetOnglet("ventes")'>Ventes</button>
    <button class="comm-tab @(onglet=="achats"?"comm-tab--active":"")" @onclick='() => SetOnglet("achats")'>Achats</button>
    <button class="comm-tab @(onglet=="clients"?"comm-tab--active":"")" @onclick='() => SetOnglet("clients")'>Clients</button>
    <button class="comm-tab @(onglet=="fournisseurs"?"comm-tab--active":"")" @onclick='() => SetOnglet("fournisseurs")'>Fournisseurs</button>
</div>

@* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   ONGLET DASHBOARD
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• *@
@if (onglet == "dashboard")
{
    @if (chargementDash) { <div class="loading-state"><div class="spinner-lg"></div></div> }
    else if (dash != null)
    {
        <div class="stat-cards-grid" style="margin-top:16px">
            <div class="stat-card stat-card--blue">
                <div class="stat-icon">C</div>
                <div class="stat-value">@dash.NbClients</div>
                <div class="stat-label">Clients actifs</div>
            </div>
            <div class="stat-card stat-card--amber">
                <div class="stat-icon">D</div>
                <div class="stat-value">@dash.DevisOuverts</div>
                <div class="stat-label">Devis ouverts</div>
            </div>
            <div class="stat-card stat-card--teal">
                <div class="stat-icon">C</div>
                <div class="stat-value">@dash.CommandesEnCours</div>
                <div class="stat-label">Commandes en cours</div>
            </div>
            <div class="stat-card stat-card--red">
                <div class="stat-icon">F</div>
                <div class="stat-value">@dash.FacturesNonReglees</div>
                <div class="stat-label">Factures à encaisser</div>
            </div>
            <div class="stat-card stat-card--green">
                <div class="stat-icon">CA</div>
                <div class="stat-value">@dash.CaMois.ToString("N0") F</div>
                <div class="stat-label">CA du mois</div>
            </div>
            <div class="stat-card @(dash.EncoursClient > 0 ? "stat-card--amber" : "stat-card--gray")">
                <div class="stat-icon">EC</div>
                <div class="stat-value">@dash.EncoursClient.ToString("N0") F</div>
                <div class="stat-label">Encours clients</div>
            </div>
            <div class="stat-card stat-card--blue">
                <div class="stat-icon">CF</div>
                <div class="stat-value">@dash.CommandesFourn</div>
                <div class="stat-label">Cdes fournisseurs</div>
            </div>
        </div>
        <div style="margin-top:24px">
            <h3 class="section-title">Flux de transformation</h3>
            <div class="flux-diagram">
                <div class="flux-group">
                    <div class="flux-title">VENTES</div>
                    <div class="flux-steps">
                        <span class="flux-step flux-step--1">Devis</span>
                        <span class="flux-arrow">→</span>
                        <span class="flux-step flux-step--2">Commande</span>
                        <span class="flux-arrow">→</span>
                        <span class="flux-step flux-step--3">Bon de livraison</span>
                        <span class="flux-arrow">→</span>
                        <span class="flux-step flux-step--4">Facture</span>
                        <span class="flux-arrow">→</span>
                        <span class="flux-step flux-step--5">Avoir</span>
                    </div>
                </div>
                <div class="flux-group" style="margin-top:12px">
                    <div class="flux-title">ACHATS</div>
                    <div class="flux-steps">
                        <span class="flux-step flux-step--1">Demande</span>
                        <span class="flux-arrow">→</span>
                        <span class="flux-step flux-step--2">Commande</span>
                        <span class="flux-arrow">→</span>
                        <span class="flux-step flux-step--3">Réception</span>
                        <span class="flux-arrow">→</span>
                        <span class="flux-step flux-step--4">Facture</span>
                        <span class="flux-arrow">→</span>
                        <span class="flux-step flux-step--5">Avoir</span>
                    </div>
                </div>
            </div>
        </div>
    }
}

@* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
   ONGLET VENTES
â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• *@
@if (onglet == "ventes")
{
    <div class="toolbar" style="margin-top:12px">
        <div class="toolbar-filters" style="flex-wrap:wrap;gap:6px">
            @foreach (var tf in TypesVente)
            {
                <button class="btn-secondary @(filtreTypeVente==tf.Id?"btn-active":"")"
                        @onclick="() => SetFiltreVente(tf.Id)">@tf.Libelle</button>
            }
        </div>
        <div class="search-box">
            <span class="search-icon">🔍</span>
            <input class="search-input" type="text" placeholder="N°, client..."
                   @bind="rechercheVente" @bind:event="oninput" />
        </div>
    </div>

    @if (chargementVentes) { <div class="loading-state"><div class="spinner-lg"></div></div> }
    else
    {
        <div class="table-container">
            <table class="data-table">
                <thead><tr>
                    <th>N° Document</th><th>Type</th><th>Client</th><th>Date</th>
                    <th class="text-right">HT</th><th class="text-right">TTC</th>
                    <th class="text-right">Solde</th><th>Statut</th><th>Actions</th>
                </tr></thead>
                <tbody>
                @foreach (var d in VentesFiltrees)
                {
                    <tr class="@(d.EstVerrouille?"row-locked":"")">
                        <td><code class="mono">@d.Numero</code></td>
                        <td><span class="badge @GetBadgeVente(d.TypeDocument)">@d.TypeLibelle</span></td>
                        <td class="cell-main">@d.ClientNom</td>
                        <td class="small text-muted">@d.DateDocument.ToString("dd/MM/yyyy")</td>
                        <td class="text-right mono small">@d.MontantHT.ToString("N2") F</td>
                        <td class="text-right mono">@d.MontantTTC.ToString("N2") F</td>
                        <td class="text-right mono @(d.Solde>0&&d.TypeDocument==4?"text-warn":"")">@d.Solde.ToString("N2") F</td>
                        <td>
                            <span class="badge @GetStatutBadgeVente(d.Statut)">@d.StatutLibelle</span>
                            @if (d.EstVerrouille) { <span style="margin-left:4px" title="Réglé">Verrouillé</span> }
                        </td>
                        <td class="actions-cell">
                            <div class="row-actions-menu row-actions-menu--inline @(venteActionsOpenId == d.Id ? "is-open" : null)">
                                <button type="button"
                                        class="btn-row-action btn-row-action--soft"
                                        @onclick="() => ToggleVenteActions(d)">
                                    Actions
                                </button>
                                @if (venteActionsOpenId == d.Id)
                                {
                                    <div class="row-actions-menu-list">
                                        <button type="button" class="btn-row-action btn-row-action--primary" @onclick="() => OuvrirConsultationVenteDepuisMenu(d)">Consulter</button>
                                        <button type="button" class="btn-row-action btn-row-action--print" @onclick="() => ImprimerVenteDepuisMenu(d)">Imprimer</button>
                                        @if (d.Statut == 1 && !d.EstVerrouille)
                                        { <button type="button" class="btn-row-action btn-row-action--success" @onclick="() => ValiderVenteDepuisMenu(d)">Valider</button> }
                                        @if (d.TypeDocument < 5 && !d.EstVerrouille && d.Statut >= 2 && d.Statut <= 7)
                                        { <button type="button" class="btn-row-action btn-row-action--warn" @onclick="() => OuvrirTransfoDepuisMenu(d)">Transformer</button> }
                                        @if (d.TypeDocument == 4 && d.Solde > 0 && !d.EstVerrouille)
                                        { <button type="button" class="btn-row-action btn-row-action--success" @onclick="() => OuvrirReglementDepuisMenu(d)">Encaisser</button> }
                                        @if (!d.EstVerrouille && d.Statut < 9)
                                        { <button type="button" class="btn-row-action btn-row-action--danger" @onclick="() => AnnulerVenteDepuisMenu(d)">Annuler</button> }
                                    </div>
                                }
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        @if (!ventes.Any()) { <div class="empty-state">Aucun document de vente. Cliquez "+ Nouveau document".</div> }
        else if (!VentesFiltrees.Any()) { <div class="empty-state">Aucun document pour ce filtre.</div> }
    }
}
@* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
