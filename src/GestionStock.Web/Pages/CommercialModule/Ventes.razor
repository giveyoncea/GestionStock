    private void FiltrerClientsRecherche(ChangeEventArgs e)
    {
        clientSearch = e.Value?.ToString() ?? "";
        if (string.IsNullOrWhiteSpace(clientSearch))
        {
            filteredClients = clients.OrderBy(c => c.RaisonSociale).Take(6).ToList();
            return;
        }

        filteredClients = clients
            .Where(c => c.RaisonSociale.Contains(clientSearch, StringComparison.OrdinalIgnoreCase)
                     || c.Code.Contains(clientSearch, StringComparison.OrdinalIgnoreCase)
                     || (c.Email ?? string.Empty).Contains(clientSearch, StringComparison.OrdinalIgnoreCase))
            .OrderBy(c => c.RaisonSociale)
            .Take(6)
            .ToList();
    }
    private void ChoisirClient(ClientDto client)
    {
        fClientId = client.Id.ToString();
        clientSearch = client.RaisonSociale;
        selectedClientLabel = client.RaisonSociale;
        filteredClients = new();
    }
    private void EffacerClientSelection()
    {
