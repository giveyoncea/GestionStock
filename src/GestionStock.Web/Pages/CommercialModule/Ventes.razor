                    <table class="data-table">
                        <thead><tr><th>Article</th><th>QtÃ©</th><th>PU HT</th><th>Total TTC</th></tr></thead>
                        <tbody>
                            @foreach (var ligne in detailDoc.Lignes.OrderBy(l => l.Ordre))
                            {
                                <tr>
