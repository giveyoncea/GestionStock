@page "/ventes"
@page "/commercial/ventes"
@page "/ventes/nouveau"
@page "/commercial/ventes/nouveau"
@page "/ventes/consultation/{DocumentId:guid}"
@page "/commercial/ventes/consultation/{DocumentId:guid}"
@page "/ventes/reglement/{ReglementDocumentId:guid}"
@page "/commercial/ventes/reglement/{ReglementDocumentId:guid}"
@attribute [Authorize]
@inject IApiService Api
@inject ICurrencyService Devise
@inject IPrintService PrintService
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IAsyncDisposable

<PageTitle>Documents de vente - GestionStock</PageTitle>

<div class="workspace-window-shell">
    <section id="ventes-workspace-window" class="workspace-window @(ventesPageMinimized ? "workspace-window--minimized" : null) @(ventesPageMaximized ? "workspace-window--maximized" : null) @((showDetail && detailDoc != null) || (showReglement && selectedDoc != null) ? "workspace-window--child-open" : null)">
        <header id="ventes-workspace-header" class="workspace-window-header workspace-window-header--draggable">
            <div>
                <h1 class="workspace-window-title">Documents de vente</h1>
                <p class="workspace-window-subtitle">Consultation, validation et suivi des statuts</p>
            </div>
            <div class="workspace-window-controls">
                <button type="button" class="workspace-window-btn" title="Réduire" @onclick="ToggleVentesPage">−</button>
                <button type="button" class="workspace-window-btn" title="@(ventesPageMaximized ? "Restaurer" : "Agrandir")" @onclick="ToggleVentesPageMaximized">@(ventesPageMaximized ? "❐" : "□")</button>
                <button type="button" class="workspace-window-btn workspace-window-btn--close" title="Fermer" @onclick="FermerVentesPage">×</button>
            </div>
        </header>

        @if (!ventesPageMinimized)
        {
            <div class="workspace-window-toolbar">
                <div class="ventes-type-tabs" role="tablist" aria-label="Types de documents">
                    @foreach (var option in typeOptions)
                    {
                        <button type="button"
                                class="chip-filter @(selectedTypeFilter == option.Value ? "chip-filter--active" : null)"
                                @onclick="() => ChangerFiltreType(option.Value)">
                            @option.Label
                        </button>
                    }
                </div>
                <div class="header-actions">
                    <button class="btn-primary" @onclick="OuvrirCreation">+ Nouveau document</button>
                </div>
            </div>

            <div class="workspace-window-body ventes-page-body @((showDetail && detailDoc != null) || (showReglement && selectedDoc != null) ? "workspace-window-body--dimmed" : null)">
                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <div class="@msgCls">@message</div>
                }

                @if (chargement)
                {
                    <div class="loading-state"><div class="spinner-lg"></div></div>
                }
                else
                {
                    <div class="ventes-table-shell">
                        <div class="ventes-table-meta">
                            <div class="text-muted">@(documents.Count) document(s)</div>
                            <div class="ventes-page-size">
                                <label class="field-label" for="ventes-page-size">Lignes par page</label>
                                <select id="ventes-page-size" class="field-input" value="@pageSize" @onchange="ChangerTaillePage">
                                    @foreach (var size in pageSizeOptions)
                                    {
                                        <option value="@size">@size</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="table-container ventes-table-container">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>No</th>
                                        <th>Type</th>
                                        <th>Client</th>
                                        <th>Date</th>
                                        <th class="text-right">Total TTC</th>
                                        <th class="text-right">Montant regle</th>
                                        <th>Statut</th>
                                        <th>Consultation</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in DocumentsPage)
                                    {
                                        <tr class="@(openActionsDocumentId == d.Id ? "ventes-row ventes-row--actions-open" : "ventes-row")" @ondblclick="() => VoirDetail(d)" style="cursor:pointer">
                                            <td @ondblclick:stopPropagation="false"><button type="button" class="btn-link-like" @onclick="() => VoirDetail(d)"><code>@d.Numero</code></button></td>
                                            <td @ondblclick="() => VoirDetail(d)">@d.TypeLibelle</td>
                                            <td @ondblclick="() => VoirDetail(d)">@d.ClientNom</td>
                                            <td @ondblclick="() => VoirDetail(d)">@d.DateDocument.ToString("dd/MM/yyyy")</td>
                                            <td class="text-right mono" @ondblclick="() => VoirDetail(d)">@Montant(d.MontantTTC)</td>
                                            <td class="text-right mono" @ondblclick="() => VoirDetail(d)">@Montant(d.MontantRegle)</td>
                                            <td @ondblclick="() => VoirDetail(d)"><span class="badge @GetStatutBadge(d.Statut)">@d.StatutLibelle</span></td>
                                            <td><button type="button" class="btn-secondary" @onclick:stopPropagation="true" @onclick="() => VoirDetail(d)">Consulter</button></td>
                                            <td class="actions-cell ventes-actions-cell @(openActionsDocumentId == d.Id ? "ventes-actions-cell--open" : null)">
                                                @if (HasActions(d))
                                                {
                                                    <button type="button"
                                                            class="btn-row-action btn-row-action--soft ventes-actions-trigger"
                                                            @onclick:stopPropagation="true"
                                                            @onclick="() => ToggleActionsMenu(d.Id)">
                                                        Actions
                                                    </button>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                        </tr>
                                        @if (openActionsDocumentId == d.Id && HasActions(d))
                                        {
                                            <tr class="ventes-actions-row">
                                                <td colspan="9">
                                                    <div class="ventes-actions-inline-panel">
                                                        @if (PeutModifier(d))
                                                        {
                                                            <button class="btn-row-action btn-row-action--primary" title="Modifier" @onclick="async () => { CloseActionsMenu(); await OuvrirEdition(d); }">Modifier</button>
                                                        }
                                                        @if (d.Statut == 1)
                                                        {
                                                            <button class="btn-row-action btn-row-action--success" title="Valider" @onclick="async () => { CloseActionsMenu(); await Valider(d); }">Valider</button>
                                                        }
                                                        @if (d.TypeDocument == 4 && d.Solde > 0 && d.Statut != 5 && d.Statut != 10)
                                                        {
                                                            <button class="btn-row-action btn-row-action--success" title="Encaisser" @onclick="() => { CloseActionsMenu(); OuvrirReglement(d); }">Encaisser</button>
                                                        }
                                                        @if (d.Statut == 4)
                                                        {
                                                            <button class="btn-row-action btn-row-action--warn" title="Comptabiliser" @onclick="async () => { CloseActionsMenu(); await Comptabiliser(d); }">Comptabiliser</button>
                                                        }
                                                        <button class="btn-row-action btn-row-action--print" title="Imprimer" @onclick="async () => { CloseActionsMenu(); await Imprimer(d); }">Imprimer</button>
                                                        @if (d.Statut != 5 && d.Statut != 10)
                                                        {
                                                            <button class="btn-row-action btn-row-action--danger" title="Annuler" @onclick="async () => { CloseActionsMenu(); await Annuler(d); }">Annuler</button>
                                                        }
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="ventes-table-footer">
                            <div class="text-muted">@PaginationResume</div>
                            <div class="pager-controls">
                                <button type="button" class="btn-secondary" @onclick="PagePrecedente" disabled="@(currentPage <= 1)">Précédent</button>
                                <span class="pager-indicator">Page @currentPage / @TotalPages</span>
                                <button type="button" class="btn-secondary" @onclick="PageSuivante" disabled="@(currentPage >= TotalPages)">Suivant</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>
</div>

@if (showForm)
{
    <div class="sales-window-shell">
        <div class="sales-window sales-window--form @(showFormMinimized ? "sales-window--minimized" : null)">
            <div class="sales-window-header">
                <div class="sales-window-title-block">
                    <h2 class="sales-window-title">@(editId.HasValue ? $"Modifier {editNumero}" : "Nouveau document de vente")</h2>
                    <span class="sales-window-subtitle">Saisie, edition et preparation du document</span>
                </div>
                <div class="sales-window-controls">
                    <button type="button" class="sales-window-control" title="Réduire" @onclick="ToggleFormMinimized">−</button>
                    <button type="button" class="sales-window-control sales-window-control--close" title="Fermer" @onclick="FermerForm">×</button>
                </div>
            </div>
            <div class="sales-window-body">
                @if (showFormMinimized)
                {
                    <div class="sales-window-minimized-note">Fenêtre réduite. Cliquez sur − pour la réouvrir.</div>
                }
                else
                {
                <div class="form-grid">
                    <div class="field-group">
                        <label class="field-label">Type *</label>
                        <select class="field-input" @bind="fType" disabled="@editId.HasValue">
                            <option value="1">Devis</option>
                            <option value="2">Commande client</option>
                            <option value="4">Facture</option>
                            <option value="5">Avoir client</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label class="field-label">Client *</label>
                        <div style="display:flex;flex-direction:column;gap:8px">
                            <div style="display:flex;gap:8px;align-items:center">
                                <input class="field-input" placeholder="Rechercher un client..." value="@clientSearch" @oninput="FiltrerClientsRecherche" />
                                <button type="button" class="btn-secondary" @onclick="OuvrirCreationClientRapide">+ Client</button>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(selectedClientLabel))
                            {
                                <div class="tiers-selected-badge">
                                    @selectedClientLabel
                                    <button class="tiers-clear-btn" @onclick="EffacerClientSelection">x</button>
                                </div>
                            }
                            @if (filteredClients.Any())
                            {
                                <div class="tiers-dropdown" style="position:static">
                                    @foreach (var client in filteredClients.Take(6))
                                    {
                                        <button type="button" class="tiers-dropdown-item" @onclick="() => ChoisirClient(client)">
                                            <span class="tiers-dd-rs">@client.RaisonSociale</span>
                                            <span class="tiers-dd-sub">@client.Code @(string.IsNullOrWhiteSpace(client.Ville) ? "" : " - " + client.Ville)</span>
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                    <div class="field-group">
                        <label class="field-label">Date</label>
                        <input class="field-input" type="date" @bind="fDate" />
                    </div>
                    <div class="field-group">
                        <label class="field-label">EchÃ©ance</label>
                        <input class="field-input" type="date" @bind="fEcheance" />
                    </div>
                    <div class="field-group">
                        <label class="field-label">@($"Frais livraison ({Devise.Symbol})")</label>
                        <input class="field-input" type="number" step="@Devise.AmountStep" @bind="fFraisLivraison" />
                    </div>
                    <div class="field-group">
                        <label class="field-label">@($"Acompte ({Devise.Symbol})")</label>
                        <input class="field-input" type="number" step="@Devise.AmountStep" @bind="fAcompte" />
                    </div>
                </div>
                <div style="margin-top:16px">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
                        <label class="field-label" style="margin:0">Lignes</label>
                        <button class="btn-secondary" @onclick="AjouterLigne">+ Ligne</button>
                    </div>
                    <div class="table-container">
                        <table class="data-table" style="font-size:12px">
                            <thead>
                                <tr>
                                    <th>Article</th>
                                    <th>QtÃ©</th>
                                    <th>PU HT</th>
                                    <th>TVA%</th>
                                    <th>Total TTC</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (var i = 0; i < lignes.Count; i++)
                                {
                                    var idx = i;
                                    <tr>
                                        <td>
                                            <select class="field-input" @bind="lignes[idx].ArticleId" @bind:after="() => OnArticleChange(idx)">
                                                <option value="">-</option>
                                                @foreach (var a in articles)
                                                {
                                                    <option value="@a.Id">[@a.Code] @a.Designation</option>
                                                }
                                            </select>
                                        </td>
                                        <td><input class="field-input" type="number" step="0.001" @bind="lignes[idx].Quantite" /></td>
                                        <td><input class="field-input" type="number" step="@Devise.AmountStep" @bind="lignes[idx].PrixUnitaireHT" /></td>
                                        <td><input class="field-input" type="number" step="0.1" @bind="lignes[idx].TauxTVA" /></td>
                                        <td class="mono">@Montant(TotalLigne(lignes[idx]))</td>
                                        <td><button class="btn-icon btn-icon-danger" @onclick="() => SupprimerLigne(idx)">X</button></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                }
            </div>
            @if (!showFormMinimized)
            {
            <div class="sales-window-footer">
                <button class="btn-secondary" @onclick="FermerForm">Annuler</button>
                <button class="btn-primary" @onclick="Enregistrer" disabled="@saving">@(saving ? "Enregistrement..." : "Enregistrer")</button>
            </div>
            }
        </div>
    </div>
}

