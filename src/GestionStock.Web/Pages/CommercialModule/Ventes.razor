@code {
    [Parameter] public Guid? DocumentId { get; set; }
    [Parameter] public Guid? ReglementDocumentId { get; set; }

    private List<DocumentVenteDto> documents = new();
    private List<ClientDto> clients = new();
    private List<ArticleDto> articles = new();
    private bool chargement = true;
    private bool saving;
    private string? message;
    private string msgCls = "alert-success";

    private bool showForm;
    private bool showDetail;
    private bool showReglement;
    private bool ventesPageMinimized;
    private bool ventesPageMaximized;
    private bool showFormMinimized;
    private bool showDetailMinimized;
    private bool showReglementMinimized;
    private bool showQuickClient;
    private Guid? openActionsDocumentId;
    private Guid? editId;
    private string editNumero = "";
    private DocumentVenteDto? selectedDoc;
    private DocumentVenteDetailDto? detailDoc;
    private int selectedTypeFilter;
    private IJSObjectReference? ventesWindowModule;
    private bool ventesWindowInitialized;

    private int fType = 1;
    private string fClientId = "";
    private DateTime fDate = DateTime.Today;
    private DateTime? fEcheance;
    private decimal fFraisLivraison;
    private decimal fAcompte;
    private List<LigneDocRequest> lignes = new();
    private decimal reglementMontant;
    private string quickClientNom = "";
    private string quickClientEmail = "";
    private string quickClientTel = "";
    private string quickClientVille = "";
    private int quickClientType = 2;
    private string clientSearch = "";
    private string selectedClientLabel = "";
    private List<ClientDto> filteredClients = new();
    private bool dataLoaded;
    private int currentPage = 1;
    private int pageSize = 10;
    private readonly int[] pageSizeOptions = [10, 20, 50, 100];
    private readonly (int Value, string Label)[] typeOptions =
    [
        (0, "Tous"),
        (1, "Devis"),
        (2, "Commandes"),
        (3, "BL"),
        (4, "Factures"),
        (5, "Avoirs")
    ];

    protected override async Task OnParametersSetAsync()
    {
        if (!dataLoaded)
        {
            await Devise.EnsureLoadedAsync();
            await Recharger();
            dataLoaded = true;
        }

        await SynchroniserDepuisRouteAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!ventesPageMaximized)
        {
            var module = await EnsureVentesWindowModuleAsync();
            if (!ventesWindowInitialized)
            {
                await module.InvokeVoidAsync("initializeFloatingWindow", "ventes-workspace-window", "ventes-workspace-header");
                ventesWindowInitialized = true;
            }
        }

        if (ventesWindowModule != null)
        {
            await ventesWindowModule.InvokeVoidAsync("setWindowMaximized", "ventes-workspace-window", ventesPageMaximized);
        }
    }

    private async Task Recharger()
    {
        chargement = true;
        documents = await Api.GetVentesAsync() ?? new();
        clients = await Api.GetClientsAsync() ?? new();
        var art = await Api.GetArticlesAsync(1, 500, null, null);
        articles = art?.Items.ToList() ?? new();
        AssurerPaginationValide();
        chargement = false;
    }

    private void OuvrirCreation()
    {
        Nav.NavigateTo("/commercial/ventes/nouveau");
    }

    private void OuvrirCreationInterne()
    {
        editId = null;
        editNumero = "";
        fType = 1;
        fClientId = "";
        clientSearch = "";
        selectedClientLabel = "";
        filteredClients = new();
        fDate = DateTime.Today;
        fEcheance = null;
        fFraisLivraison = 0;
        fAcompte = 0;
        lignes = new() { new LigneDocRequest { TauxTVA = 20 } };
        showFormMinimized = false;
        showDetail = false;
        showForm = true;
    }

    private async Task OuvrirEdition(DocumentVenteDto document)
    {
        var data = await Api.GetVenteAsync(document.Id);
        if (data == null) return;
        editId = data.Id;
        editNumero = data.Numero;
        fType = data.TypeDocument;
        fClientId = data.ClientId.ToString();
        selectedClientLabel = data.ClientNom;
        clientSearch = data.ClientNom;
        filteredClients = new();
        fDate = data.DateDocument;
        fEcheance = data.DateEcheance;
        fFraisLivraison = data.FraisLivraison;
        fAcompte = data.MontantAcompte;
        lignes = data.Lignes.Select(l => new LigneDocRequest
        {
            ArticleId = l.ArticleId,
            Designation = l.Designation,
            Quantite = l.Quantite,
            PrixUnitaireHT = l.PrixUnitaireHT,
            TauxRemise = l.TauxRemise,
            TauxTVA = l.TauxTVA,
            NumeroLot = l.NumeroLot
        }).ToList();
