    };

    private string Montant(decimal value) => Devise.FormatAmount(value);

    private IEnumerable<DocumentVenteDto> DocumentsFiltres =>
        selectedTypeFilter == 0
            ? documents
            : documents.Where(d => d.TypeDocument == selectedTypeFilter);

    private IEnumerable<DocumentVenteDto> DocumentsPage =>
        DocumentsFiltres
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize);

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(DocumentsFiltres.Count() / (double)pageSize));

    private string PaginationResume
    {
        get
        {
            var total = DocumentsFiltres.Count();
            if (total == 0)
                return "Aucun document";

            var debut = ((currentPage - 1) * pageSize) + 1;
            var fin = Math.Min(currentPage * pageSize, total);
            return $"{debut}-{fin} sur {total}";
        }
    }

    private void AssurerPaginationValide()
    {
        if (currentPage < 1)
            currentPage = 1;

        if (currentPage > TotalPages)
            currentPage = TotalPages;
    }

    private void ChangerTaillePage(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var newSize) && pageSizeOptions.Contains(newSize))
        {
            pageSize = newSize;
            currentPage = 1;
            AssurerPaginationValide();
        }
    }

    private void PagePrecedente()
    {
        if (currentPage > 1)
            currentPage--;
    }

    private void PageSuivante()
    {
        if (currentPage < TotalPages)
            currentPage++;
    }

    private bool EstRouteCreation()
    {
        var path = Nav.ToBaseRelativePath(Nav.Uri).Split('?', '#')[0].Trim('/').ToLowerInvariant();
        return path is "ventes/nouveau" or "commercial/ventes/nouveau";
    }

    private bool EstRouteConsultation() => DocumentId.HasValue;
    private bool EstRouteReglement() => ReglementDocumentId.HasValue;

    private void FermerFormInterne()
    {
        showForm = false;
        showFormMinimized = false;
    }

    private void FermerDetailInterne()
    {
        showDetail = false;
        showDetailMinimized = false;
    }

    private void FermerReglementInterne()
    {
        showReglement = false;
        showReglementMinimized = false;
    }

    private async Task VoirDetailInterne(Guid id)
    {
        detailDoc = await Api.GetVenteAsync(id);
        showDetailMinimized = false;
        showReglement = false;
        showForm = false;
        showDetail = detailDoc != null;
    }

    private async Task OuvrirReglementInterne(Guid id)
    {
        var doc = documents.FirstOrDefault(d => d.Id == id);
        if (doc == null)
        {
            var detail = await Api.GetVenteAsync(id);
            if (detail == null)
                return;

            doc = new DocumentVenteDto
            {
                Id = detail.Id,
                Numero = detail.Numero,
                TypeDocument = detail.TypeDocument,
                TypeLibelle = detail.TypeLibelle,
                Statut = detail.Statut,
                StatutLibelle = detail.StatutLibelle,
                ClientId = detail.ClientId,
                ClientNom = detail.ClientNom,
                DateDocument = detail.DateDocument,
                DateEcheance = detail.DateEcheance,
                MontantHT = detail.MontantHT,
                MontantTVA = detail.MontantTVA,
                MontantTTC = detail.MontantTTC,
                MontantRegle = detail.MontantRegle,
                Solde = detail.MontantTTC - detail.MontantRegle,
                FraisLivraison = detail.FraisLivraison,
                MontantAcompte = detail.MontantAcompte,
                EstVerrouille = detail.EstVerrouille
            };
        }

        selectedDoc = doc;
        reglementMontant = doc.Solde;
        showReglementMinimized = false;
        showForm = false;
        showDetail = false;
        showReglement = true;
    }

    private async Task SynchroniserDepuisRouteAsync()
    {
        if (EstRouteCreation())
        {
            OuvrirCreationInterne();
            return;
        }

        if (EstRouteConsultation())
        {
            await VoirDetailInterne(DocumentId!.Value);
            return;
        }

        if (EstRouteReglement())
        {
            await OuvrirReglementInterne(ReglementDocumentId!.Value);
            return;
        }

        if (showDetail)
            FermerDetailInterne();

        if (showReglement)
            FermerReglementInterne();

        if (showForm && !editId.HasValue)
            FermerFormInterne();
    }

    private async ValueTask<IJSObjectReference> EnsureVentesWindowModuleAsync()
    {
        ventesWindowModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/windowing.js");
        return ventesWindowModule;
    }

    public async ValueTask DisposeAsync()
    {
        if (ventesWindowModule is not null)
        {
            try
            {
                await ventesWindowModule.DisposeAsync();
            }
            catch
            {
            }
        }
    }
