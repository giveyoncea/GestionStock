    private bool HasActions(DocumentVenteDto d) =>
        PeutModifier(d)
        || d.Statut == 1
        || (d.TypeDocument == 4 && d.Solde > 0 && d.Statut != 5 && d.Statut != 10)
        || d.Statut == 4
        || (d.Statut != 5 && d.Statut != 10);
    private static bool PeutModifier(DocumentVenteDto d) => d.Statut == 1 && !d.EstVerrouille && d.TypeDocument != 3;
    private void AjouterLigne() => lignes.Add(new LigneDocRequest { TauxTVA = 20 });
    private void SupprimerLigne(int index) { if (index >= 0 && index < lignes.Count) lignes.RemoveAt(index); }

    private void OnArticleChange(int index)
    {
        var article = articles.FirstOrDefault(a => a.Id == lignes[index].ArticleId);
        if (article != null)
        {
            lignes[index].Designation = article.Designation;
            lignes[index].PrixUnitaireHT = article.PrixAchat;
            lignes[index].TauxTVA = 20;
        }
    }

    private decimal TotalLigne(LigneDocRequest ligne) => ligne.Quantite * ligne.PrixUnitaireHT * (1 + ligne.TauxTVA / 100);

    private async Task Enregistrer()
    {
        if (!Guid.TryParse(fClientId, out var clientId) || !lignes.Any())
            return;
        saving = true;
        var payload = new DocumentVenteRequest
        {
            TypeDocument = fType,
            ClientId = clientId,
            DateDocument = fDate,
            DateEcheance = fEcheance,
            FraisLivraison = fFraisLivraison,
            MontantAcompte = fAcompte,
            Lignes = lignes
        };
        var result = editId.HasValue ? await Api.ModifierVenteAsync(editId.Value, payload) : await Api.CreerVenteAsync(payload);
        saving = false;
        msgCls = result?.Succes == true ? "alert-success" : "alert-error";
        message = result?.Message;
        if (result?.Succes == true)
        {
            if (EstRouteCreation())
            {
                Nav.NavigateTo("/commercial/ventes");
                return;
            }

            FermerFormInterne();
            await Recharger();
        }
    }

