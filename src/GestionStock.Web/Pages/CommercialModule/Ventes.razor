                <div class="sales-window-title-block">
                    <h2 class="sales-window-title">Consultation - @detailDoc.Numero</h2>
                    <span class="sales-window-subtitle">Ventes / Consultation</span>
                </div>
                <div class="sales-window-controls">
                    <button type="button" class="sales-window-control" title="Réduire" @onclick="ToggleDetailMinimized">−</button>
                    <button type="button" class="sales-window-control sales-window-control--close" title="Fermer" @onclick="FermerDetail">×</button>
                </div>
            </div>
            <div class="sales-window-body">
                @if (showDetailMinimized)
                {
                    <div class="sales-window-minimized-note">Fenêtre réduite. Cliquez sur − pour la réouvrir.</div>
                }
                else
                {
                <div class="form-grid">
                    <div class="field-group"><label class="field-label">Type</label><div class="field-input">@detailDoc.TypeLibelle</div></div>
                    <div class="field-group"><label class="field-label">Statut</label><div class="field-input">@detailDoc.StatutLibelle</div></div>
                    <div class="field-group"><label class="field-label">Client</label><div class="field-input">@detailDoc.ClientNom</div></div>
                    <div class="field-group"><label class="field-label">Date</label><div class="field-input">@detailDoc.DateDocument.ToString("dd/MM/yyyy")</div></div>
