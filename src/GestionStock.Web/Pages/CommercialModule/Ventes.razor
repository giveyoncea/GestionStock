        <div class="sales-window sales-window--reglement @(showReglementMinimized ? "sales-window--minimized" : null)">
            <div class="sales-window-header">
                <div class="sales-window-title-block">
                    <h2 class="sales-window-title">Règlement - @selectedDoc.Numero</h2>
